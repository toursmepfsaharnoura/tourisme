{
  "name": "inside-tunisia",
  "version": "1.0.0",
  "description": "Tourism web application for Tunisia",
  "main": "backend/app.js",
  "scripts": {
    "build:css": "tailwindcss -i ./frontend/public/css/input.css -o ./frontend/public/css/style.css",
    "watch:css": "tailwindcss -i ./frontend/public/css/input.css -o ./frontend/public/css/style.css --watch",
    "start": "node backend/app.js",
    "dev": "nodemon backend/app.js",
    "prod": "npm run build:css && NODE_ENV=production node backend/app.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "tourism",
    "tunisia",
    "express",
    "handlebars"
  ],
  "author": "Your Name",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "express-handlebars": "^7.1.3",
    "express-session": "^1.19.0",
    "express-validator": "^7.0.1",
    "glob": "^13.0.6",
    "hbs": "^4.2.0",
    "jsonwebtoken": "^9.0.3",
    "method-override": "^3.0.0",
    "multer": "^1.4.5-lts.1",
    "mysql": "^2.18.1",
    "mysql2": "^3.17.1",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.24",
    "nodemon": "^3.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1"
  }
}
