<!DOCTYPE html>
<html>
<head>
  <title>Notifications Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="max-w-4xl mx-auto mt-10 bg-white p-6 rounded-xl shadow">

  <h1 class="text-2xl font-bold mb-6">🔔 Notifications Admin</h1>

  <!-- TABS (NO JS - LINKS ONLY) -->
  <div class="flex gap-3 mb-6">

    <a href="/notifications/admin?type=ALL"
       class="px-3 py-2 rounded bg-gray-200">
      All
    </a>

    <a href="/notifications/admin?type=MESSAGE"
       class="px-3 py-2 rounded bg-blue-200">
      Messages
    </a>

    <a href="/notifications/admin?type=DOCUMENT"
       class="px-3 py-2 rounded bg-green-200">
      Documents
    </a>

    <a href="/notifications/admin?type=PLAN"
       class="px-3 py-2 rounded bg-purple-200">
      Plans
    </a>

  </div>

  <!-- LIST -->
  {{#each notifications}}

    <div class="bg-gray-50 p-4 mb-3 rounded flex justify-between items-center">

      <div>
        <p class="font-semibold">{{this.message}}</p>
        <small class="text-gray-400">{{this.type}}</small>
      </div>

      <a href="/notifications/{{this.id}}"
         class="bg-blue-500 text-white px-3 py-1 rounded">
        Voir
      </a>

    </div>

  {{/each}}

</div>

</body>
</html>