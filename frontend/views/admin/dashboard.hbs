  <!-- JavaScript pour les notifications aux guides -->
  <script>
    // Formulaire d'envoi de notifications
    document.getElementById('sendNotificationForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const guideId = document.getElementById('guideId').value;
      const type = document.getElementById('notificationType').value;
      const message = document.getElementById('notificationMessage').value;
      
      try {
        const response = await fetch('/notifications/sendToGuide', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            guideId: guideId,
            type: type,
            message: message
          })
        });
        
        const result = await response.json();
        
        const resultDiv = document.getElementById('notificationResult');
        if (result.success) {
          resultDiv.style.background = '#d4edda';
          resultDiv.style.color = '#155724';
          resultDiv.style.border = '1px solid #c3e6cb';
          resultDiv.innerHTML = '<i class="fas fa-check-circle"></i> Notification envoyée avec succès au guide ' + guideId;
          
          // Réinitialiser le formulaire
          document.getElementById('sendNotificationForm').reset();
        } else {
          resultDiv.style.background = '#f8d7da';
          resultDiv.style.color = '#721c24';
          resultDiv.style.border = '1px solid #f5c6cb';
          resultDiv.innerHTML = '<i class="fas fa-exclamation-circle"></i> Erreur: ' + result.message;
        }
        
        resultDiv.style.display = 'block';
        
        // Cacher le message après 5 secondes
        setTimeout(() => {
          resultDiv.style.display = 'none';
        }, 5000);
        
      } catch (error) {
        console.error('Erreur:', error);
        const resultDiv = document.getElementById('notificationResult');
        resultDiv.style.background = '#f8d7da';
        resultDiv.style.color = '#721c24';
        resultDiv.style.border = '1px solid #f5c6cb';
        resultDiv.innerHTML = '<i class="fas fa-exclamation-circle"></i> Erreur de connexion';
        resultDiv.style.display = 'block';
      }
    });
    
    // Fonction de test rapide
    function testNotification() {
      document.getElementById('guideId').value = '1';
      document.getElementById('notificationType').value = 'reply';
      document.getElementById('notificationMessage').value = 'Ceci est un message de test de l\'admin. Votre plan a été approuvé!';
      
      // Soumettre automatiquement
      document.getElementById('sendNotificationForm').dispatchEvent(new Event('submit'));
    }
  </script>
