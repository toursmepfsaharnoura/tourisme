<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Conversations avec les Guides</title>
  <script src="/socket.io/socket.io.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    .conversation-item {
      transition: all 0.3s ease;
    }
    
    .conversation-item:hover {
      background: #f8f9fa;
      transform: translateX(5px);
    }
    
    .unread-badge {
      animation: pulse 2s infinite;
    }
    
    @keyframes pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.1); }
      100% { transform: scale(1); }
    }
    
    .status-indicator {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      display: inline-block;
    }
    
    .status-active { background-color: #4caf50; }
    .status-inactive { background-color: #9e9e9e; }
    .status-bloque { background-color: #f44336; }
  </style>
</head>
<body class="bg-gray-100">
  <!-- Header -->
  <header class="bg-white shadow-sm border-b">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center">
          <i class="fas fa-comments text-blue-600 text-2xl mr-3"></i>
          <h1 class="text-xl font-semibold text-gray-900">Conversations avec les Guides</h1>
        </div>
        <div class="flex items-center space-x-4">
          <span class="text-sm text-gray-600">
            <i class="fas fa-user-circle mr-1"></i>
            {{user.nom_complet}}
          </span>
          <a href="/admin/dashboard" class="text-gray-500 hover:text-gray-700">
            <i class="fas fa-arrow-left"></i> Retour
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
          <div class="p-3 bg-blue-100 rounded-full">
            <i class="fas fa-users text-blue-600"></i>
          </div>
          <div class="ml-4">
            <p class="text-sm text-gray-600">Total Guides</p>
            <p class="text-xl font-semibold">{{guides.length}}</p>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
          <div class="p-3 bg-green-100 rounded-full">
            <i class="fas fa-comments text-green-600"></i>
          </div>
          <div class="ml-4">
            <p class="text-sm text-gray-600">Conversations Actives</p>
            <p class="text-xl font-semibold">{{#each guides}}{{#if unread_count}}1{{/if}}{{/each}}</p>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
          <div class="p-3 bg-yellow-100 rounded-full">
            <i class="fas fa-envelope text-yellow-600"></i>
          </div>
          <div class="ml-4">
            <p class="text-sm text-gray-600">Messages Non Lus</p>
            <p class="text-xl font-semibold">{{#each guides}}{{unread_count}}{{/each}}</p>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
          <div class="p-3 bg-purple-100 rounded-full">
            <i class="fas fa-user-check text-purple-600"></i>
          </div>
          <div class="ml-4">
            <p class="text-sm text-gray-600">Guides Actifs</p>
            <p class="text-xl font-semibold">{{#each guides}}{{#if (eq statut 'ACTIF')}}1{{/if}}{{/each}}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Search and Filter -->
    <div class="bg-white rounded-lg shadow p-4 mb-6">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between space-y-4 md:space-y-0">
        <div class="flex-1 max-w-md">
          <div class="relative">
            <input 
              type="text" 
              id="searchInput"
              placeholder="Rechercher un guide..." 
              class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            >
            <i class="fas fa-search absolute left-3 top-3 text-gray-400"></i>
          </div>
        </div>
        <div class="flex space-x-2">
          <select id="statusFilter" class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
            <option value="">Tous les statuts</option>
            <option value="ACTIF">Actifs</option>
            <option value="INACTIF">Inactifs</option>
            <option value="BLOQUE">Bloqués</option>
          </select>
          <button id="refreshBtn" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
            <i class="fas fa-sync-alt mr-2"></i>Rafraîchir
          </button>
        </div>
      </div>
    </div>

    <!-- Conversations List -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Liste des Conversations</h2>
      </div>
      
      {{#if guides.length}}
        <div class="divide-y divide-gray-200" id="conversationsList">
          {{#each guides}}
            <div class="conversation-item px-6 py-4 hover:bg-gray-50 cursor-pointer" 
                 onclick="openConversation({{id}}, '{{nom_complet}}', '{{statut}}')"
                 data-guide-id="{{id}}"
                 data-guide-name="{{nom_complet}}"
                 data-status="{{statut}}">
              <div class="flex items-center justify-between">
                <div class="flex items-center flex-1">
                  <!-- Avatar -->
                  <div class="flex-shrink-0 mr-4">
                    {{#if photo_profil}}
                      <img src="{{photo_profil}}" alt="{{nom_complet}}" class="w-12 h-12 rounded-full object-cover">
                    {{else}}
                      <div class="w-12 h-12 bg-gray-300 rounded-full flex items-center justify-center">
                        <i class="fas fa-user text-gray-600"></i>
                      </div>
                    {{/if}}
                  </div>
                  
                  <!-- Info Guide -->
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between">
                      <div class="flex items-center">
                        <h3 class="text-sm font-medium text-gray-900 truncate">
                          {{nom_complet}}
                        </h3>
                        <span class="status-indicator status-{{#if (eq statut 'ACTIF')}}active{{else if (eq statut 'BLOQUE')}}bloque{{else}}inactive{{/if}} ml-2"></span>
                      </div>
                      <div class="flex items-center space-x-2">
                        {{#if unread_count}}
                          <span class="unread-badge inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                            {{unread_count}} non lu(s)
                          </span>
                        {{/if}}
                        <span class="text-xs text-gray-500">
                          {{#if last_message_date}}
                            {{formatDate last_message_date}}
                          {{else}}
                            Pas de conversation
                          {{/if}}
                        </span>
                      </div>
                    </div>
                    
                    <div class="flex items-center justify-between mt-1">
                      <p class="text-sm text-gray-600 truncate">
                        {{#if last_message}}
                          {{last_message}}
                        {{else}}
                          <span class="text-gray-400">Aucun message</span>
                        {{/if}}
                      </p>
                      <span class="text-xs px-2 py-1 rounded-full 
                        {{#if (eq statut 'ACTIF')}}bg-green-100 text-green-800
                        {{else if (eq statut 'BLOQUE')}}bg-red-100 text-red-800
                        {{else}}bg-gray-100 text-gray-800{{/if}}">
                        {{statut}}
                      </span>
                    </div>
                  </div>
                </div>
                
                <!-- Actions -->
                <div class="flex items-center space-x-2 ml-4">
                  <button onclick="event.stopPropagation(); openConversation({{id}}, '{{nom_complet}}', '{{statut}}')" 
                          class="p-2 text-blue-600 hover:bg-blue-100 rounded-lg transition"
                          title="Ouvrir la conversation">
                    <i class="fas fa-comment"></i>
                  </button>
                  {{#if email}}
                    <button onclick="event.stopPropagation(); sendEmail('{{email}}')" 
                            class="p-2 text-green-600 hover:bg-green-100 rounded-lg transition"
                            title="Envoyer un email">
                      <i class="fas fa-envelope"></i>
                    </button>
                  {{/if}}
                </div>
              </div>
            </div>
          {{/each}}
        </div>
      {{else}}
        <div class="text-center py-12">
          <i class="fas fa-comments text-gray-400 text-5xl mb-4"></i>
          <h3 class="text-lg font-medium text-gray-900 mb-2">Aucune conversation</h3>
          <p class="text-gray-600">Aucun guide n'a encore initié de conversation avec l'administrateur.</p>
        </div>
      {{/if}}
    </div>
  </main>

  <!-- JavaScript -->
  <script>
    const socket = io();
    
    // Join admin room
    socket.on('connect', () => {
      socket.emit('joinAdmin');
      console.log('Connecté au serveur Socket.IO');
    });

    // Search functionality
    document.getElementById('searchInput').addEventListener('input', (e) => {
      const searchTerm = e.target.value.toLowerCase();
      const conversations = document.querySelectorAll('.conversation-item');
      
      conversations.forEach(conv => {
        const name = conv.dataset.guideName.toLowerCase();
        if (name.includes(searchTerm)) {
          conv.style.display = 'block';
        } else {
          conv.style.display = 'none';
        }
      });
    });

    // Status filter
    document.getElementById('statusFilter').addEventListener('change', (e) => {
      const status = e.target.value;
      const conversations = document.querySelectorAll('.conversation-item');
      
      conversations.forEach(conv => {
        const convStatus = conv.dataset.status;
        if (!status || convStatus === status) {
          conv.style.display = 'block';
        } else {
          conv.style.display = 'none';
        }
      });
    });

    // Refresh button
    document.getElementById('refreshBtn').addEventListener('click', () => {
      location.reload();
    });

    // Open conversation
    function openConversation(guideId, guideName, status) {
      window.location.href = `/admin/chat/${guideId}`;
    }

    // Send email
    function sendEmail(email) {
      window.location.href = `mailto:${email}`;
    }

    // Listen for real-time updates
    socket.on('new_message', (data) => {
      console.log('Nouveau message reçu:', data);
      // Rafraîchir la page pour montrer les nouveaux messages
      location.reload();
    });

    socket.on('guide_typing', (data) => {
      console.log('Guide en train d\'écrire:', data);
      // Afficher un indicateur de frappe si nécessaire
    });

    // Format date helper
    function formatDate(dateString) {
      const date = new Date(dateString);
      const now = new Date();
      const diffMs = now - date;
      const diffMins = Math.floor(diffMs / 60000);
      const diffHours = Math.floor(diffMs / 3600000);
      const diffDays = Math.floor(diffMs / 86400000);

      if (diffMins < 1) return 'À l\'instant';
      if (diffMins < 60) return `Il y a ${diffMins} min`;
      if (diffHours < 24) return `Il y a ${diffHours} h`;
      if (diffDays < 7) return `Il y a ${diffDays} j`;
      
      return date.toLocaleDateString('fr-FR');
    }
  </script>
</body>
</html>
