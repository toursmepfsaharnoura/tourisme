<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chat avec les Guides</title>
  <script src="/socket.io/socket.io.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    .message-container {
      max-height: calc(100vh - 200px);
      overflow-y: auto;
      scroll-behavior: smooth;
    }
    
    .message-bubble {
      max-width: 70%;
      word-wrap: break-word;
    }
    
    .message-sent {
      background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
      color: white;
      margin-left: auto;
    }
    
    .message-received {
      background: #f8f9fa;
      color: #212529;
      border: 1px solid #dee2e6;
    }
    
    .guide-list {
      max-height: calc(100vh - 100px);
      overflow-y: auto;
    }
    
    .guide-item {
      transition: all 0.3s ease;
    }
    
    .guide-item:hover {
      background: #f8f9fa;
      transform: translateX(5px);
    }
    
    .guide-item.active {
      background: #e3f2fd;
      border-left: 4px solid #2196f3;
    }
    
    .unread-badge {
      animation: pulse 2s infinite;
    }
    
    @keyframes pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.1); }
      100% { transform: scale(1); }
    }
    
    .online-indicator {
      width: 10px;
      height: 10px;
      background: #4caf50;
      border-radius: 50%;
      border: 2px solid white;
      position: absolute;
      bottom: 0;
      right: 0;
    }
    
    .message-time {
      font-size: 0.75rem;
      opacity: 0.7;
    }
  </style>
</head>

<body class="bg-gray-50">
  <!-- Header -->
  <header class="bg-white shadow-sm border-b">
    <div class="container mx-auto px-4 py-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <a href="/admin/dashboard" class="text-gray-600 hover:text-gray-900">
            <i class="fas fa-arrow-left"></i>
          </a>
          <h1 class="text-xl font-semibold text-gray-900">
            <i class="fas fa-comments"></i> Chat avec les Guides
          </h1>
        </div>
        <div class="flex items-center space-x-2">
          <span class="text-sm text-gray-500">{{user.nom_complet}}</span>
          <div class="relative">
            <img src="/images/admin-avatar.png" alt="Admin" class="w-8 h-8 rounded-full">
            <div class="online-indicator"></div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <div class="flex h-screen pt-16">
    <!-- Guide List Sidebar -->
    <div class="w-80 bg-white border-r">
      <div class="p-4 border-b">
        <div class="relative">
          <input 
            type="text" 
            id="searchGuide" 
            placeholder="Rechercher un guide..." 
            class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
          >
          <i class="fas fa-search absolute left-3 top-3 text-gray-400"></i>
        </div>
      </div>
      
      <div class="guide-list p-2" id="guideList">
        {{#if guides.length}}
          {{#each guides}}
            <div class="guide-item p-3 rounded-lg cursor-pointer hover:bg-gray-50" 
                 onclick="selectGuide({{this.id}}, '{{this.nom_complet}}')"
                 data-guide-id="{{this.id}}">
              <div class="flex items-center space-x-3">
                <div class="relative">
                  <img src="/images/default-avatar.png" alt="{{this.nom_complet}}" 
                       class="w-10 h-10 rounded-full">
                  <div class="online-indicator"></div>
                </div>
                <div class="flex-1">
                  <div class="flex items-center justify-between">
                    <h4 class="font-semibold text-gray-900">{{this.nom_complet}}</h4>
                    {{#if this.unread_count}}
                      <span class="unread-badge bg-red-500 text-white text-xs px-2 py-1 rounded-full">
                        {{this.unread_count}}
                      </span>
                    {{/if}}
                  </div>
                  <p class="text-sm text-gray-500 truncate">{{this.last_message}}</p>
                  <p class="text-xs text-gray-400">{{formatRelativeTimeSimple this.last_message_time}}</p>
                </div>
              </div>
            </div>
          {{/each}}
        {{else}}
          <div class="text-center py-8">
            <i class="fas fa-users text-4xl text-gray-300 mb-3"></i>
            <p class="text-gray-500">Aucun guide trouvé</p>
          </div>
        {{/if}}
      </div>
    </div>

    <!-- Chat Area -->
    <div class="flex-1 flex flex-col">
      {{#if selectedGuide}}
        <!-- Chat Header -->
        <div class="bg-white border-b px-6 py-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
              <div class="relative">
                <img src="/images/default-avatar.png" alt="{{selectedGuide.nom_complet}}" 
                     class="w-10 h-10 rounded-full">
                <div class="online-indicator"></div>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">{{selectedGuide.nom_complet}}</h3>
                <p class="text-sm text-green-600">Guide en ligne</p>
              </div>
            </div>
            <div class="flex items-center space-x-2">
              <button class="text-gray-600 hover:text-gray-900">
                <i class="fas fa-phone"></i>
              </button>
              <button class="text-gray-600 hover:text-gray-900">
                <i class="fas fa-video"></i>
              </button>
              <button class="text-gray-600 hover:text-gray-900">
                <i class="fas fa-info-circle"></i>
              </button>
            </div>
          </div>
        </div>

        <!-- Messages Container -->
        <div class="flex-1 bg-gray-50">
          <div class="message-container p-4 space-y-4" id="messagesContainer">
            {{#if messages.length}}
              {{#each messages}}
                <div class="flex {{#if (eq this.id_expediteur ../user.id)}}justify-end{{else}}justify-start{{/if}}">
                  <div class="message-bubble rounded-2xl px-4 py-2 shadow-sm
                    {{#if (eq this.id_expediteur ../user.id)}}message-sent{{else}}message-received{{/if}}">
                    <p class="text-sm">{{this.contenu}}</p>
                    <div class="message-time mt-1">
                      {{formatTime this.date_creation}}
                      {{#if (eq this.id_expediteur ../user.id)}}
                        {{#if this.est_lu}}
                          <i class="fas fa-check-double text-blue-400 ml-1"></i>
                        {{else}}
                          <i class="fas fa-check text-gray-400 ml-1"></i>
                        {{/if}}
                      {{/if}}
                    </div>
                  </div>
                </div>
              {{/each}}
            {{else}}
              <div class="text-center py-8">
                <i class="fas fa-comments text-4xl text-gray-300 mb-3"></i>
                <p class="text-gray-500">Aucun message dans cette conversation</p>
                <p class="text-sm text-gray-400 mt-2">Envoyez votre premier message à {{selectedGuide.nom_complet}}</p>
              </div>
            {{/if}}
          </div>
        </div>

        <!-- Message Input -->
        <div class="bg-white border-t p-4">
          <form id="messageForm" class="flex items-center space-x-2">
            <div class="flex-1 relative">
              <input 
                type="text" 
                id="messageInput" 
                name="message"
                placeholder="Tapez votre message..." 
                class="w-full px-4 py-3 border border-gray-300 rounded-full focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                autocomplete="off"
              >
              <button type="button" class="absolute right-2 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-gray-600">
                <i class="fas fa-paperclip"></i>
              </button>
            </div>
            <button 
              type="submit" 
              id="sendButton"
              class="bg-blue-600 text-white px-6 py-3 rounded-full hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed transition-all"
            >
              <i class="fas fa-paper-plane"></i>
            </button>
          </form>
          
          <!-- Typing Indicator -->
          <div id="typingIndicator" class="hidden mt-2">
            <div class="flex items-center space-x-2 text-sm text-gray-500">
              <div class="flex space-x-1">
                <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce"></div>
                <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0.1s"></div>
                <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
              </div>
              <span>{{selectedGuide.nom_complet}} est en train d'écrire...</span>
            </div>
          </div>
        </div>
      {{else}}
        <!-- No Guide Selected -->
        <div class="flex-1 flex items-center justify-center bg-gray-50">
          <div class="text-center">
            <i class="fas fa-comments text-6xl text-gray-300 mb-4"></i>
            <h3 class="text-xl font-semibold text-gray-700 mb-2">Sélectionnez un guide</h3>
            <p class="text-gray-500">Choisissez un guide dans la liste pour commencer à discuter</p>
          </div>
        </div>
      {{/if}}
    </div>
  </div>

  <script>
    const socket = io();
    const adminId = {{user.id}};
    let selectedGuideId = {{#if selectedGuide}}{{selectedGuide.id}}{{else}}null{{/if}};
    let lastMessageId = {{#if messages.length}}{{messages.[0].id}}{{else}}0{{/if}};

    // Join admin room
    socket.emit('joinAdmin', adminId);
    
    // Scroll to bottom on load
    window.addEventListener('load', () => {
      if (selectedGuideId) {
        scrollToBottom();
      }
    });

    // Search guides
    document.getElementById('searchGuide').addEventListener('input', (e) => {
      const searchTerm = e.target.value.toLowerCase();
      const guideItems = document.querySelectorAll('.guide-item');
      
      guideItems.forEach(item => {
        const guideName = item.querySelector('h4').textContent.toLowerCase();
        if (guideName.includes(searchTerm)) {
          item.style.display = 'block';
        } else {
          item.style.display = 'none';
        }
      });
    });

    // Select guide
    function selectGuide(guideId, guideName) {
      // Remove active class from all items
      document.querySelectorAll('.guide-item').forEach(item => {
        item.classList.remove('active');
      });
      
      // Add active class to selected item
      document.querySelector(`[data-guide-id="${guideId}"]`).classList.add('active');
      
      // Redirect to chat with selected guide
      window.location.href = `/admin/chat/${guideId}`;
    }

    // Send message
    document.getElementById('messageForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      if (!selectedGuideId) return;
      
      const input = document.getElementById('messageInput');
      const content = input.value.trim();
      
      if (!content) return;
      
      const sendButton = document.getElementById('sendButton');
      sendButton.disabled = true;
      sendButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
      
      try {
        const response = await fetch(`/admin/chat/${selectedGuideId}/send`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            message: content
          })
        });
        
        const result = await response.json();
        
        if (result.success) {
          input.value = '';
          // Message will be added via socket.io
        } else {
          alert('Erreur: ' + result.message);
        }
      } catch (error) {
        console.error('Error sending message:', error);
        alert('Erreur de connexion. Veuillez réessayer.');
      } finally {
        sendButton.disabled = false;
        sendButton.innerHTML = '<i class="fas fa-paper-plane"></i>';
      }
    });

    // Listen for new messages from guides
    socket.on('admin_message', (data) => {
      if (data.guideId === selectedGuideId) {
        addMessageToChat(data, false);
        scrollToBottom();
      }
      
      // Update unread count in guide list
      updateGuideUnreadCount(data.guideId, 1);
    });

    // Listen for typing indicators
    socket.on('guide_typing', (data) => {
      if (data.guideId === selectedGuideId) {
        const indicator = document.getElementById('typingIndicator');
        if (data.isTyping) {
          indicator.classList.remove('hidden');
        } else {
          indicator.classList.add('hidden');
        }
      }
    });

    // Send typing indicator
    let typingTimeout;
    document.getElementById('messageInput').addEventListener('input', () => {
      if (!selectedGuideId) return;
      
      socket.emit('admin_typing', {
        guideId: selectedGuideId,
        isTyping: true
      });
      
      clearTimeout(typingTimeout);
      typingTimeout = setTimeout(() => {
        socket.emit('admin_typing', {
          guideId: selectedGuideId,
          isTyping: false
        });
      }, 1000);
    });

    function addMessageToChat(message, isSent) {
      const container = document.getElementById('messagesContainer');
      const messageDiv = document.createElement('div');
      
      const messageClass = isSent ? 'justify-end' : 'justify-start';
      const bubbleClass = isSent ? 'message-sent' : 'message-received';
      
      messageDiv.className = `flex ${messageClass}`;
      messageDiv.innerHTML = `
        <div class="message-bubble rounded-2xl px-4 py-2 shadow-sm ${bubbleClass}">
          <p class="text-sm">${message.content}</p>
          <div class="message-time mt-1">
            ${new Date(message.date).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })}
            ${isSent ? '<i class="fas fa-check text-gray-400 ml-1"></i>' : ''}
          </div>
        </div>
      `;
      
      container.appendChild(messageDiv);
    }

    function scrollToBottom() {
      const container = document.getElementById('messagesContainer');
      container.scrollTop = container.scrollHeight;
    }

    function updateGuideUnreadCount(guideId, count) {
      const guideItem = document.querySelector(`[data-guide-id="${guideId}"]`);
      if (guideItem) {
        const badge = guideItem.querySelector('.unread-badge');
        if (badge) {
          const currentCount = parseInt(badge.textContent);
          badge.textContent = currentCount + count;
        } else {
          const nameElement = guideItem.querySelector('h4');
          const badge = document.createElement('span');
          badge.className = 'unread-badge bg-red-500 text-white text-xs px-2 py-1 rounded-full';
          badge.textContent = count;
          nameElement.appendChild(badge);
        }
      }
    }
  </script>
</body>
</html>
