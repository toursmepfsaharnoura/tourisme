<!DOCTYPE html>
<html>
<head>
  <title>Validation Guides - Admin</title>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');
    body { font-family: 'Inter', sans-serif; }
    .gradient-primary { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .gradient-success { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
    .gradient-danger { background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); }
    .gradient-warning { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); }
    .hover-lift { transition: all 0.3s; }
    .hover-lift:hover { transform: translateY(-4px); box-shadow: 0 10px 30px rgba(0,0,0,0.15); }
    .badge-pulse { animation: pulse 2s infinite; }
    @keyframes pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.05); }
      100% { transform: scale(1); }
    }
  </style>
</head>
<body class="bg-gray-50">
  <div class="min-h-screen">
    <!-- Header -->
    <div class="gradient-primary text-white shadow-lg">
      <div class="max-w-7xl mx-auto px-6 py-6">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-3xl font-bold">🏛️ Validation Guides</h1>
            <p class="text-blue-100 mt-1">Gestion des demandes guides et abonnements</p>
          </div>
          <div class="flex items-center space-x-4">
            <span class="bg-white/20 px-4 py-2 rounded-full text-sm">
              Admin: {{user.nom_complet}}
            </span>
            <a href="/admin/dashboard" class="nav-btn">🏠 Dashboard</a>
            <a href="/admin/messages" class="nav-btn">💬 Messages</a>
            <a href="/logout" class="nav-btn">🚪 Déconnexion</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="max-w-7xl mx-auto px-6 py-8">
      <div class="grid md:grid-cols-4 gap-6 mb-8">
        <div class="bg-white rounded-xl shadow-lg p-6 hover-lift">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-gray-500 text-sm">En attente CV</p>
              <p class="text-3xl font-bold text-orange-600">{{stats.cv_attente}}</p>
            </div>
            <div class="bg-orange-100 p-3 rounded-full">
              <i class="fas fa-file-alt text-orange-600 text-xl"></i>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl shadow-lg p-6 hover-lift">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-gray-500 text-sm">Guides actifs</p>
              <p class="text-3xl font-bold text-green-600">{{stats.guides_actifs}}</p>
            </div>
            <div class="bg-green-100 p-3 rounded-full">
              <i class="fas fa-user-check text-green-600 text-xl"></i>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl shadow-lg p-6 hover-lift">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-gray-500 text-sm">Abonnements actifs</p>
              <p class="text-3xl font-bold text-blue-600">{{stats.abonnements_actifs}}</p>
            </div>
            <div class="bg-blue-100 p-3 rounded-full">
              <i class="fas fa-credit-card text-blue-600 text-xl"></i>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl shadow-lg p-6 hover-lift">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-gray-500 text-sm">Messages non lus</p>
              <p class="text-3xl font-bold text-purple-600">{{stats.messages_non_lus}}</p>
            </div>
            <div class="bg-purple-100 p-3 rounded-full">
              <i class="fas fa-envelope text-purple-600 text-xl"></i>
            </div>
          </div>
        </div>
      </div>

      <!-- Filtres -->
      <div class="bg-white rounded-xl shadow-lg p-6 mb-8">
        <div class="flex flex-wrap gap-4 items-center">
          <div class="flex items-center space-x-2">
            <label class="text-sm font-medium text-gray-700">Statut:</label>
            <select id="statusFilter" class="border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-transparent">
              <option value="">Tous</option>
              <option value="EN_ATTENTE">En attente</option>
              <option value="ACTIF">Actifs</option>
              <option value="BLOQUE">Bloqués</option>
            </select>
          </div>
          <div class="flex items-center space-x-2">
            <label class="text-sm font-medium text-gray-700">CV:</label>
            <select id="cvFilter" class="border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-transparent">
              <option value="">Tous</option>
              <option value="0">Non approuvé</option>
              <option value="1">Approuvé</option>
            </select>
          </div>
          <button onclick="applyFilters()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg transition-all">
            <i class="fas fa-filter mr-2"></i>Filtrer
          </button>
        </div>
      </div>

      <!-- Liste des guides -->
      <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <div class="bg-gray-50 px-6 py-4 border-b">
          <h2 class="text-xl font-bold text-gray-900">📋 Demandes en cours</h2>
        </div>
        
        <div class="divide-y divide-gray-200">
          {{#each guides}}
          <div class="p-6 hover:bg-gray-50 transition-colors">
            <div class="flex items-start justify-between">
              <!-- Info guide -->
              <div class="flex-1">
                <div class="flex items-center space-x-4 mb-3">
                  <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-purple-600 rounded-full flex items-center justify-center text-white font-bold text-lg">
                    {{ this.nom_complet }}
                  </div>
                  <div>
                    <h3 class="text-lg font-semibold text-gray-900">{{this.nom_complet}}</h3>
                    <p class="text-gray-600">{{this.email}}</p>
                  </div>
                </div>
                
                <!-- Badges -->
                <div class="flex flex-wrap gap-2 mb-3">
                  {{#if this.cv}}
                  <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">
                    📄 CV déposé
                  </span>
                  {{else}}
                  <span class="bg-gray-100 text-gray-800 px-3 py-1 rounded-full text-sm font-medium">
                    📄 Pas de CV
                  </span>
                  {{/if}}
                  
                  {{#if this.cv_approved}}
                  <span class="bg-emerald-100 text-emerald-800 px-3 py-1 rounded-full text-sm font-medium">
                    ✅ CV approuvé
                  </span>
                  {{else}}
                  <span class="bg-orange-100 text-orange-800 px-3 py-1 rounded-full text-sm font-medium badge-pulse">
                    ⏳ CV en attente
                  </span>
                  {{/if}}
                  
                  {{#if this.abonnement_actif}}
                  <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm font-medium">
                    💳 Abonnement actif
                  </span>
                  {{else}}
                  <span class="bg-gray-100 text-gray-800 px-3 py-1 rounded-full text-sm font-medium">
                    💳 Pas d'abonnement
                  </span>
                  {{/if}}
                  
                  <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-medium">
                    {{this.statut}}
                  </span>
                </div>

                <!-- Messages récents -->
                {{#if this.last_message}}
                <div class="bg-gray-50 rounded-lg p-3 mb-3">
                  <p class="text-sm text-gray-600">
                    <strong>Dernier message:</strong> "{{this.last_message}}"
                    <span class="text-gray-400 ml-2">{{ this.last_date}}</span>
                  </p>
                </div>
                {{/if}}
              </div>

              <!-- Actions -->
              <div class="flex flex-col space-y-2 ml-6">
                {{#unless this.cv_approved}}
                <button onclick="approveCV({{this.id_utilisateur}})" class="gradient-success text-white px-4 py-2 rounded-lg hover:shadow-lg transition-all text-sm font-medium">
                  ✅ Approuver CV
                </button>
                <button onclick="rejectCV({{this.id_utilisateur}})" class="gradient-danger text-white px-4 py-2 rounded-lg hover:shadow-lg transition-all text-sm font-medium">
                  ❌ Rejeter CV
                </button>
                {{/unless}}
                
                {{#unless this.abonnement_actif}}
                {{#if this.cv_approved}}
                <button onclick="activateAbonnement({{this.id_utilisateur}})" class="gradient-warning text-white px-4 py-2 rounded-lg hover:shadow-lg transition-all text-sm font-medium">
                  💳 Activer Abonnement
                </button>
                {{/if}}
                {{/unless}}
                
                <button onclick="viewMessages({{this.id_utilisateur}})" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg hover:shadow-lg transition-all text-sm font-medium">
                  💬 Voir Messages
                </button>
                
                <button onclick="viewProfile({{this.id_utilisateur}})" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg hover:shadow-lg transition-all text-sm font-medium">
                  👤 Voir Profil
                </button>
              </div>
            </div>
          </div>
          {{/each}}
          
          {{#unless guides.length}}
          <div class="p-12 text-center text-gray-500">
            <div class="text-6xl mb-4">📭</div>
            <p class="text-xl">Aucune demande en cours</p>
            <p class="text-gray-400 mt-2">Toutes les validations sont à jour!</p>
          </div>
          {{/unless}}
        </div>
      </div>
    </div>
  </div>

  <script>
    // Approuver CV
    async function approveCV(guideId) {
      if (confirm('Approuver le CV de ce guide ?')) {
        try {
          const response = await fetch(`/admin/cv/${guideId}/approve`, { method: 'POST' });
          const data = await response.json();
          
          if (data.success) {
            showNotification('✅ CV approuvé avec succès!', 'success');
            setTimeout(() => location.reload(), 1500);
          } else {
            showNotification('❌ Erreur: ' + data.error, 'error');
          }
        } catch (error) {
          showNotification('❌ Erreur serveur', 'error');
        }
      }
    }

    // Rejeter CV
    async function rejectCV(guideId) {
      const raison = prompt('Raison du rejet (optionnel):');
      try {
        const response = await fetch(`/admin/cv/${guideId}/reject`, { 
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ raison })
        });
        const data = await response.json();
        
        if (data.success) {
          showNotification('❌ CV rejeté', 'warning');
          setTimeout(() => location.reload(), 1500);
        } else {
          showNotification('❌ Erreur: ' + data.error, 'error');
        }
      } catch (error) {
        showNotification('❌ Erreur serveur', 'error');
      }
    }

    // Activer abonnement
    async function activateAbonnement(guideId) {
      if (confirm('Activer l\'abonnement mensuel (29€) pour ce guide ?')) {
        try {
          const response = await fetch(`/admin/abonnement/${guideId}/activate`, { method: 'POST' });
          const data = await response.json();
          
          if (data.success) {
            showNotification('💳 Abonnement activé!', 'success');
            setTimeout(() => location.reload(), 1500);
          } else {
            showNotification('❌ Erreur: ' + data.error, 'error');
          }
        } catch (error) {
          showNotification('❌ Erreur serveur', 'error');
        }
      }
    }

    // Voir messages
    function viewMessages(guideId) {
      window.location.href = `/admin/messages/${guideId}`;
    }

    // Voir profil
    function viewProfile(guideId) {
      window.location.href = `/admin/guide/${guideId}`;
    }

    // Notifications
    function showNotification(message, type = 'info') {
      const notification = document.createElement('div');
      const colors = {
        success: 'bg-green-500',
        error: 'bg-red-500',
        warning: 'bg-orange-500',
        info: 'bg-blue-500'
      };
      
      notification.className = `fixed top-4 right-4 ${colors[type]} text-white px-6 py-4 rounded-2xl shadow-xl z-50 transform transition-all duration-300 translate-x-full`;
      notification.textContent = message;
      document.body.appendChild(notification);
      
      setTimeout(() => notification.classList.remove('translate-x-full'), 100);
      setTimeout(() => {
        notification.classList.add('translate-x-full');
        setTimeout(() => notification.remove(), 300);
      }, 3000);
    }

    // Filtres
    function applyFilters() {
      const status = document.getElementById('statusFilter').value;
      const cv = document.getElementById('cvFilter').value;
      
      let url = '/admin/validation-guides';
      const params = new URLSearchParams();
      
      if (status) params.append('status', status);
      if (cv) params.append('cv', cv);
      
      if (params.toString()) {
        url += '?' + params.toString();
      }
      
      window.location.href = url;
    }
  </script>
</body>
</html>