<!-- Hero Section -->
<section class="relative h-screen flex items-center justify-center bg-cover bg-center" style="background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1950&q=80');">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/30"></div>
  <div class="relative z-10 text-center text-white px-4 max-w-4xl mx-auto">
    <div class="animate-slide-up">
      <h1 class="text-5xl md:text-7xl font-bold mb-6 text-shadow-glow font-playfair">
        Explore Tunisia<br>
        <span class="text-ocean-light">like never before</span>
      </h1>
      <p class="text-xl md:text-2xl mb-12 text-gray-200 max-w-2xl mx-auto">
        Discover authentic experiences, certified guides, and unforgettable journeys across the beautiful landscapes of Tunisia
      </p>
      
      <!-- Search Bar -->
      <div class="max-w-2xl mx-auto mb-8">
        <div class="glass-morphism rounded-2xl p-2 flex flex-col md:flex-row gap-2">
          <div class="flex-1 flex items-center px-4">
            <i class="fas fa-search text-gray-400 mr-3"></i>
            <input 
              type="text" 
              placeholder="Search destinations, activities, or guides..." 
              class="w-full bg-transparent text-white placeholder-gray-400 outline-none py-3"
              id="heroSearch"
            >
          </div>
          <button class="desert-gradient px-8 py-3 rounded-xl font-semibold text-white button-glow hover:scale-105 transition-transform">
            Search
          </button>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 text-white animate-bounce">
    <i class="fas fa-chevron-down text-2xl"></i>
  </div>
</section>

<!-- Popular Destinations -->
<section class="py-20 bg-gradient-to-b from-gray-50 to-white">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4 font-playfair">
        Popular Destinations
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Explore Tunisia's most breathtaking locations and hidden gems
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
      {{#each gouvernorats}}
      <div class="group cursor-pointer" onclick="window.location.href='/gouvernorats/{{id}}/delegations'">
        <div class="relative overflow-hidden rounded-2xl card-hover">
          <!-- Destination Image -->
          <div class="h-64 bg-gradient-to-br from-ocean-blue to-desert-orange relative">
            <div class="absolute inset-0 flex items-center justify-center">
              <i class="fas fa-map-marker-alt text-6xl text-white/30"></i>
            </div>
            <!-- Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            
            <!-- Favorite Button -->
            <button onclick="event.stopPropagation(); toggleFavoriteDestination(this)" data-gouvernorat="{{id}}" class="favorite-btn absolute top-4 right-4 w-10 h-10 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center text-white hover:bg-white/30 transition-colors">
              <i class="far fa-heart"></i>
            </button>
            
            <!-- Rating Badge -->
            <div class="absolute bottom-4 left-4 bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full">
              <div class="flex items-center text-white text-sm">
                <i class="fas fa-star text-yellow-400 mr-1"></i>
                <span>4.8</span>
              </div>
            </div>
          </div>
          
          <!-- Content -->
          <div class="p-6 bg-white rounded-b-2xl shadow-lg">
            <h3 class="text-xl font-bold text-gray-900 mb-2">{{nom}}</h3>
            <p class="text-gray-600 text-sm mb-4">Discover the wonders of {{nom}}</p>
            <div class="flex items-center justify-between">
              <div class="flex items-center text-gray-500 text-sm">
                <i class="fas fa-map-pin mr-2"></i>
                <span>Tunisia</span>
              </div>
              <div class="text-ocean-blue font-semibold">
                Explore →
              </div>
            </div>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
</section>

