<script>
// Search functionality
document.getElementById('heroSearch')?.addEventListener('keypress', function(e) {
  if (e.key === 'Enter') {
    const query = this.value.trim();
    if (query) {
      window.location.href = `/search?q=${encodeURIComponent(query)}`;
    }
  }
});

// Add entrance animations on scroll
const observerOptions = {
  threshold: 0.1,
  rootMargin: '0px 0px -50px 0px'
};

const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('animate-slide-up');
    }
  });
}, observerOptions);

// Observe all sections
document.querySelectorAll('section').forEach(section => {
  observer.observe(section);
});

// Add smooth scroll behavior
document.documentElement.style.scrollBehavior = 'smooth';

// Mobile menu toggle (if needed)
const mobileMenuButton = document.querySelector('button[class*="lg:hidden"]');
if (mobileMenuButton) {
  mobileMenuButton.addEventListener('click', function() {
    // Toggle mobile menu logic here
    console.log('Mobile menu clicked');
  });
}

// Favorite toggle function
async function toggleFavoriteDestination(button) {
  // For now, this redirects to the plans page with the gouvernorat filter
  // When a full favorite system is implemented, this will save to user's favorites
  const gouvernoratId = button.dataset.gouvernorat;
  
  // Check if user is logged in
  const isLoggedIn = {{#if user}}true{{else}}false{{/if}};
  
  if (!isLoggedIn) {
    // Redirect to login
    alert('Veuillez vous connecter pour ajouter aux favoris');
    window.location.href = '/auth/login?redirect=/gouvernorats/' + gouvernoratId + '/delegations';
  } else {
    // Show message and redirect to view plans
    window.location.href = '/gouvernorats/' + gouvernoratId + '/delegations';
  }
}
}
</script>
