          </div>
          <button class="ocean-gradient text-white px-4 py-2 rounded-lg text-sm font-medium hover:scale-105 transition-transform">
            Voir Profil
          </button>
        </div>
        
        <!-- Guide Card 4 -->
        <div class="text-center group">
          <div class="relative mb-4">
            <div class="w-32 h-32 mx-auto rounded-full bg-gradient-to-br from-ocean-blue to-sage-green p-1">
              <div class="w-full h-full rounded-full bg-gray-200 flex items-center justify-center">
                <i class="fas fa-user text-4xl text-gray-400"></i>
              </div>
            </div>
            <div class="absolute -bottom-2 left-1/2 transform -translate-x-1/2 bg-green-500 text-white px-3 py-1 rounded-full text-xs font-semibold">
              Disponible
            </div>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Leila Toumi</h3>
          <p class="text-gray-600 text-sm mb-3">Archéologie & Patrimoine</p>
          <div class="flex items-center justify-center text-yellow-400 mb-3">
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star-half-alt"></i>
            <span class="text-gray-600 text-sm ml-2">4.7</span>
          </div>
          <button class="ocean-gradient text-white px-4 py-2 rounded-lg text-sm font-medium hover:scale-105 transition-transform">
            Voir Profil
          </button>
        </div>
      </div>
      
      <div class="text-center mt-12">
        <a href="/inscription?role=GUIDE" class="desert-gradient text-white px-8 py-3 rounded-xl font-bold text-lg hover:scale-105 transition-transform">
          <i class="fas fa-user-tie mr-2"></i>
          Devenir Guide
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-r from-ocean-blue to-desert-orange relative overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-0 left-0 w-full h-full bg-black/20"></div>
      <div class="wave-animation absolute inset-0"></div>
    </div>
  
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 font-playfair">
        Prêt pour Votre Aventure Tunisienne?
      </h2>
      <p class="text-xl text-white/90 mb-12 max-w-2xl mx-auto">
        Rejoignez des milliers de voyageurs qui ont découvert la magie de la Tunisie avec nos guides experts et expériences curatées
      </p>
      
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href="/gouvernorats/1/delegations" class="bg-white text-ocean-blue px-8 py-4 rounded-2xl font-bold text-lg shadow-2xl hover:scale-105 transition-transform duration-300">
          <i class="fas fa-search mr-2"></i>
          Réserver Votre Voyage
        </a>
        <a href="/inscription" class="bg-transparent border-2 border-white text-white px-8 py-4 rounded-2xl font-bold text-lg hover:bg-white hover:text-ocean-blue transition-all duration-300">
          <i class="fas fa-user-plus mr-2"></i>
          Nous Rejoindre
        </a>
      </div>
      
      <!-- Stats -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mt-20">
        <div class="text-center">
          <div class="text-4xl font-bold text-white mb-2">50K+</div>
          <div class="text-white/80">Voyageurs Heureux</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-white mb-2">200+</div>
          <div class="text-white/80">Guides Experts</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-white mb-2">4.9</div>
          <div class="text-white/80">Note Moyenne</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter Section -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h3 class="text-3xl font-bold text-gray-900 mb-4">Restez Informé</h3>
      <p class="text-gray-600 mb-8">Recevez les derniers conseils de voyage et offres exclusives directement dans votre boîte mail</p>
      
      <form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto" onsubmit="subscribeNewsletter(event)">
        <input 
          type="email" 
          placeholder="Entrez votre email" 
          required
          class="flex-1 px-4 py-3 rounded-xl border border-gray-300 focus:border-ocean-blue focus:outline-none"
          id="newsletterEmail"
        >
        <button type="submit" class="ocean-gradient px-6 py-3 rounded-xl text-white font-semibold hover:scale-105 transition-transform">
          S'abonner
        </button>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-gray-900 text-white py-12">
