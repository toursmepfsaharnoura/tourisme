<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Explore Tunisia - Votre Passerelle vers les Aventures Tunisiennes</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Custom Styles -->
  <style>
    :root {
      --ocean-blue: #0891b2;
      --desert-orange: #ea580c;
      --sage-green: #16a34a;
      --ocean-light: #06b6d4;
    }

    body {
      font-family: 'Inter', sans-serif;
    }

    .font-playfair {
      font-family: 'Playfair Display', serif;
    }

    /* Gradients */
    .ocean-gradient {
      background: linear-gradient(135deg, var(--ocean-blue), var(--ocean-light));
    }

    .desert-gradient {
      background: linear-gradient(135deg, var(--desert-orange), #f97316);
    }

    .sage-gradient {
      background: linear-gradient(135deg, var(--sage-green), #22c55e);
    }

    /* Animations */
    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes glow {
      0%, 100% { text-shadow: 0 0 20px rgba(6, 182, 212, 0.5); }
      50% { text-shadow: 0 0 30px rgba(6, 182, 212, 0.8); }
    }

    @keyframes wave {
      0% { transform: translateX(0) translateY(0); }
      25% { transform: translateX(-20px) translateY(-10px); }
      50% { transform: translateX(-40px) translateY(5px); }
      75% { transform: translateX(-20px) translateY(-5px); }
      100% { transform: translateX(0) translateY(0); }
    }

    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-20px); }
    }

    .animate-slide-up {
      animation: slideUp 0.8s ease-out forwards;
    }

    .text-shadow-glow {
      animation: glow 3s ease-in-out infinite;
    }

    .wave-animation {
      background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="%23ffffff20" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,133.3C960,128,1056,96,1152,90.7C1248,85,1344,107,1392,117.3L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>') repeat-x;
      animation: wave 10s linear infinite;
    }

    .animate-float {
      animation: float 6s ease-in-out infinite;
    }

    /* Glass Morphism */
    .glass-morphism {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
    }

    /* Card Hover Effects */
    .card-hover {
      transition: all 0.3s ease;
    }

    .card-hover:hover {
      transform: translateY(-10px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    .button-glow {
      transition: all 0.3s ease;
    }

    .button-glow:hover {
      box-shadow: 0 10px 30px rgba(6, 182, 212, 0.4);
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
      .text-5xl { font-size: 2.5rem; }
      .text-7xl { font-size: 3.5rem; }
    }
  </style>
</head>
<body class="bg-gray-50">
  <!-- Navigation -->
  <nav class="fixed top-0 w-full bg-white/95 backdrop-blur-md shadow-sm z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <!-- Logo -->
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <h1 class="text-2xl font-bold text-ocean-blue font-playfair">
              <i class="fas fa-compass mr-2"></i>Explore Tunisia
            </h1>
          </div>
        </div>

        <!-- Desktop Navigation -->
        <div class="hidden md:block">
          <div class="ml-10 flex items-baseline space-x-8">
            <a href="#destinations" class="text-gray-700 hover:text-ocean-blue px-3 py-2 text-sm font-medium transition-colors">
              Destinations
            </a>
            <a href="#why-us" class="text-gray-700 hover:text-ocean-blue px-3 py-2 text-sm font-medium transition-colors">
              Pourquoi la Tunisie
            </a>
            <a href="#guides" class="text-gray-700 hover:text-ocean-blue px-3 py-2 text-sm font-medium transition-colors">
              Guides
            </a>
            <a href="/login" class="text-gray-700 hover:text-ocean-blue px-3 py-2 text-sm font-medium transition-colors">
              Connexion
            </a>
            <a href="/inscription" class="ocean-gradient text-white px-4 py-2 rounded-lg text-sm font-medium">
              Inscription
            </a>
          </div>
        </div>

        <!-- Mobile menu button -->
        <div class="md:hidden">
          <button type="button" class="text-gray-700 hover:text-ocean-blue p-2">
            <i class="fas fa-bars text-xl"></i>
          </button>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center bg-cover bg-center mt-16" style="background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1950&q=80');">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/50 to-black/70"></div>
  
    <!-- Animated Background Elements -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-20 left-10 w-72 h-72 bg-purple-500/20 rounded-full blur-3xl animate-float"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-pink-500/20 rounded-full blur-3xl animate-float" style="animation-delay: 2s;"></div>
      <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-blue-500/20 rounded-full blur-3xl animate-float" style="animation-delay: 4s;"></div>
    </div>
  
    <div class="relative z-10 text-center text-white px-4 max-w-5xl mx-auto">
      <div class="animate-slide-up">
        <h1 class="text-5xl md:text-7xl font-bold mb-6 text-shadow-glow font-playfair">
          Explorez la Tunisie<br>
          <span class="text-ocean-light">comme jamais auparavant</span>
        </h1>
        <p class="text-xl md:text-2xl mb-12 text-gray-200 max-w-3xl mx-auto leading-relaxed">
          Découvrez des expériences authentiques, des guides certifiés et des voyages inoubliables à travers les magnifiques paysages de la Tunisie
        </p>
        
        <!-- Search Bar -->
        <div class="max-w-2xl mx-auto mb-12">
          <form action="/search" method="GET" class="glass-morphism rounded-2xl p-2 backdrop-blur-xl border border-white/20 shadow-2xl">
            <div class="flex flex-col md:flex-row gap-2">
              <div class="flex-1 flex items-center px-6">
                <i class="fas fa-search text-gray-300 mr-4 text-lg"></i>
                <input 
                  type="text" 
                  name="q"
                  placeholder="Rechercher destinations, activités ou guides..." 
                  class="w-full bg-transparent text-white placeholder-gray-400 outline-none py-4 text-lg"
                >
              </div>
              <button type="submit" class="desert-gradient px-8 py-4 rounded-xl font-semibold text-white button-glow hover:scale-105 transition-transform">
                <i class="fas fa-search mr-2"></i>
                Rechercher
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  
    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 text-white animate-bounce">
      <i class="fas fa-chevron-down text-2xl"></i>
    </div>
  </section>

  <!-- Popular Destinations -->
  <section id="destinations" class="py-20 bg-gradient-to-b from-gray-50 to-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 font-playfair">
          Destinations Populaires
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Explorez les endroits les plus époustouflants de la Tunisie et ses trésors cachés
        </p>
      </div>
      
      <!-- Responsive Grid -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {{#each gouvernorats}}
        <div class="group relative">
          <!-- Card -->
          <div class="relative overflow-hidden rounded-2xl shadow-lg card-hover bg-white">
            <!-- Image Container -->
            <div class="relative h-48 overflow-hidden">
              {{#if image}}
                <img src="{{image}}" alt="{{nom}}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" referrerpolicy="no-referrer">
                <!-- Gradient Overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
              {{else}}
                <!-- Gradient Placeholder -->
                <div class="w-full h-full bg-gradient-to-br from-ocean-blue to-desert-orange relative">
                  <div class="absolute inset-0 bg-black/20"></div>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <i class="fas fa-map-marked-alt text-white text-4xl opacity-50"></i>
                  </div>
                </div>
              {{/if}}
              
              <!-- Heart Button -->
              <button class="absolute top-3 right-3 w-10 h-10 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center text-white hover:bg-white/30 transition-all duration-300 border border-white/30">
                <i class="far fa-heart text-lg"></i>
              </button>
              
              <!-- Rating Badge -->
              <div class="absolute bottom-3 left-3 bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full border border-white/30">
                <div class="flex items-center text-white text-sm">
                  <i class="fas fa-star text-yellow-400 mr-1"></i>
                  <span>4.8</span>
                </div>
              </div>
            </div>
            
            <!-- Content -->
            <div class="p-4">
              <h3 class="text-lg font-bold text-gray-900 mb-2">{{nom}}</h3>
              <p class="text-gray-600 text-sm mb-3">Découvrez les merveilles de {{nom}}</p>
              
              <!-- Location Info -->
              <div class="flex items-center text-gray-500 text-sm mb-4">
                <i class="fas fa-map-pin mr-2"></i>
                <span>Tunisie</span>
              </div>
              
              <!-- Discover Button -->
              <button onclick="window.location.href='/gouvernorats/{{id}}/delegations'" class="w-full ocean-gradient text-white font-semibold py-3 rounded-xl transition-all duration-300 hover:scale-105 shadow-md hover:shadow-lg">
                <i class="fas fa-compass mr-2"></i>
                Découvrir
              </button>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section id="why-us" class="py-20 bg-gradient-to-b from-white to-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 font-playfair">
          Pourquoi Choisir la Tunisie
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Une destination unique qui combine histoire, culture, paysages et hospitalité
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="text-center group">
          <div class="w-20 h-20 ocean-gradient rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg">
            <i class="fas fa-certificate text-white text-3xl"></i>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Guides Certifiés</h3>
          <p class="text-gray-600 leading-relaxed">
            Des guides locaux professionnels, passionnés et qui donnent vie à la riche histoire et culture de la Tunisie
          </p>
        </div>
        
        <!-- Feature 2 -->
        <div class="text-center group">
          <div class="w-20 h-20 desert-gradient rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg">
            <i class="fas fa-calendar-check text-white text-3xl"></i>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Réservation Facile</h3>
          <p class="text-gray-600 leading-relaxed">
            Système de réservation simple, sécurisé et instantané avec politiques d'annulation flexibles et support 24/7
          </p>
        </div>
        
        <!-- Feature 3 -->
        <div class="text-center group">
          <div class="w-20 h-20 sage-gradient rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg">
            <i class="fas fa-star text-white text-3xl"></i>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Expériences Uniques</h3>
          <p class="text-gray-600 leading-relaxed">
            Visites exclusives et activités qui mettent en valeur la beauté authentique et les trésors cachés de la Tunisie
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Guides Section -->
  <section id="guides" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 font-playfair">
