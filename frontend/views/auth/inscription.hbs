<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inscription - Tunisie Authentique</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">
  
  <!-- Travel Agency Theme Colors -->
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'travel-blue': '#1e3a8a',
            'travel-sky': '#0ea5e9',
            'travel-sand': '#fbbf24',
            'travel-sunset': '#f97316',
            'travel-olive': '#84cc16',
            'travel-teal': '#14b8a6',
            'travel-coral': '#fb7185'
          },
          fontFamily: {
            'poppins': ['Poppins', 'sans-serif'],
            'playfair': ['Playfair Display', 'serif']
          }
        }
      }
    }
  </script>
  
  <style>
    body {
      font-family: 'Poppins', sans-serif;
    }
    
    .glass { 
      background: rgba(255,255,255,0.1); 
      backdrop-filter: blur(20px); 
      border: 1px solid rgba(255,255,255,0.2); 
    }
    
    .glass-dark { 
      background: rgba(30,58,138,0.8); 
      backdrop-filter: blur(20px); 
      border: 1px solid rgba(255,255,255,0.1); 
    }
    
    .travel-gradient {
      background: linear-gradient(135deg, #1e3a8a 0%, #0ea5e9 50%, #14b8a6 100%);
    }
    
    .sunset-gradient {
      background: linear-gradient(135deg, #fbbf24 0%, #f97316 50%, #fb7185 100%);
    }
    
    .travel-pattern {
      background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    
    .input-focus {
      transition: all 0.3s ease;
    }
    
    .input-focus:focus {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(251, 191, 36, 0.3);
    }
  </style>
</head>
<body class="travel-gradient travel-pattern min-h-screen text-white">

  <!-- Background Hero -->
  <div class="fixed inset-0 z-0">
    <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1950&q=80" 
         alt="Tunisian Beach" class="w-full h-full object-cover">
    <div class="absolute inset-0 bg-gradient-to-b from-travel-blue/90 via-travel-blue/80 to-travel-teal/90"></div>
  </div>

  <!-- Main Content -->
  <div class="relative z-10 flex items-center justify-center min-h-screen px-4 py-12">
    <div class="w-full max-w-2xl">
      
      <!-- Registration Card -->
      <div class="glass-dark rounded-3xl p-8 md:p-12 shadow-2xl backdrop-blur-xl border border-white/10">
        
        <!-- Header -->
        <div class="text-center mb-10">
          <div class="inline-flex items-center justify-center w-20 h-20 bg-gradient-to-br from-travel-sand to-travel-sunset rounded-full mb-6 shadow-lg">
            <i class="fas fa-globe-africa text-3xl text-white"></i>
          </div>
          <h1 class="font-playfair text-4xl md:text-5xl font-bold text-white mb-3 text-shadow">Rejoignez l'Aventure</h1>
          <p class="text-lg text-gray-200">Créez votre compte et découvrez la Tunisie authentique</p>
        </div>

        <!-- Error Message -->
        {{#if error}}
          <div class="bg-red-500/20 border border-red-500 text-red-100 px-6 py-4 rounded-xl mb-8 backdrop-blur-sm">
            <div class="flex items-center">
              <i class="fas fa-exclamation-triangle mr-3 text-xl"></i>
              <span class="font-medium">{{error}}</span>
            </div>
          </div>
        {{/if}}

        <!-- Registration Form -->
        <form class="form-inscription space-y-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <!-- Full Name -->
            <div class="space-y-3">
              <label class="block text-white font-semibold text-base flex items-center">
                <i class="fas fa-user mr-2 text-travel-sand"></i>
                Nom Complet
              </label>
              <input type="text" name="nom_complet" required
                     class="w-full px-4 py-4 rounded-xl bg-white/10 border border-white/20 text-white placeholder-white/60 focus:outline-none focus:border-travel-sand focus:bg-white/20 input-focus transition-all"
                     placeholder="John Doe"
                     value="{{data.nom_complet}}">
            </div>

            <!-- Email Address -->
            <div class="space-y-3">
              <label class="block text-white font-semibold text-base flex items-center">
                <i class="fas fa-envelope mr-2 text-travel-sand"></i>
                Adresse Email
              </label>
              <input type="email" name="email" required
                     class="w-full px-4 py-4 rounded-xl bg-white/10 border border-white/20 text-white placeholder-white/60 focus:outline-none focus:border-travel-sand focus:bg-white/20 input-focus transition-all"
                     placeholder="john.doe@example.com"
                     value="{{data.email}}">
            </div>

            <!-- Password -->
            <div class="space-y-3">
              <label class="block text-white font-semibold text-base flex items-center">
                <i class="fas fa-lock mr-2 text-travel-sand"></i>
                Mot de Passe
              </label>
              <input type="password" name="mot_de_passe" required
                     class="w-full px-4 py-4 rounded-xl bg-white/10 border border-white/20 text-white placeholder-white/60 focus:outline-none focus:border-travel-sand focus:bg-white/20 input-focus transition-all"
                     placeholder="•••••••">
            </div>

            <!-- Account Type -->
            <div class="space-y-3">
              <label class="block text-white font-semibold text-base flex items-center">
                <i class="fas fa-users mr-2 text-travel-sand"></i>
                Type de Compte
              </label>
              <select name="role" required
                      class="w-full px-4 py-4 rounded-xl bg-white/10 border border-white/20 text-white focus:outline-none focus:border-travel-sand focus:bg-white/20 input-focus transition-all appearance-none cursor-pointer">
                <option value="" class="bg-travel-blue">Choisissez votre type de compte</option>
                <option value="TOURISTE" {{#if (eq data.role "TOURISTE")}}selected{{/if}} class="bg-travel-blue">🌍 Touriste</option>
                <option value="GUIDE" {{#if (eq data.role "GUIDE")}}selected{{/if}} class="bg-travel-blue">👨‍🏫 Guide Touristique</option>
              </select>
            </div>
          </div>

          <!-- Terms and Conditions -->
          <div class="flex items-start space-x-4 p-4 bg-white/5 rounded-xl">
            <input type="checkbox" name="terms" required
                   class="mt-1 w-5 h-5 rounded border-2 border-travel-sand bg-white/10 focus:ring-2 focus:ring-travel-sand/50 text-travel-sand">
            <label class="text-gray-200 text-sm leading-relaxed">
              J'accepte les <a href="/terms" class="text-travel-sand hover:text-travel-sunset underline transition-colors font-medium">Conditions Générales d'Utilisation</a> 
              et la <a href="/privacy" class="text-travel-sand hover:text-travel-sunset underline transition-colors font-medium">Politique de Confidentialité</a>
            </label>
          </div>

          <!-- Submit Button -->
          <button type="submit" 
                  class="w-full sunset-gradient text-white py-5 rounded-xl font-bold text-xl hover:shadow-travel-sunset/30 transform hover:scale-[1.02] transition-all duration-300 shadow-xl backdrop-blur-sm flex items-center justify-center space-x-3">
            <i class="fas fa-rocket text-xl"></i>
            <span>Commencer l'Aventure</span>
          </button>
        </form>

        <!-- Verification Section -->
        <div class="form-verification space-y-8" style="display:none;">
          <div class="text-center space-y-6">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-gradient-to-br from-travel-olive to-travel-teal rounded-full shadow-lg">
              <i class="fas fa-envelope text-3xl text-white"></i>
            </div>
            <div>
              <h3 class="font-playfair text-3xl font-bold text-white mb-3">Vérification par Email</h3>
              <p class="text-gray-200 text-lg">Un email contenant votre code de vérification a été envoyé</p>
            </div>
          </div>
          
          <div class="space-y-4">
            <label class="block text-white font-semibold text-base text-center flex items-center justify-center">
              <i class="fas fa-shield-alt mr-2 text-travel-olive"></i>
              Code de Vérification
            </label>
            <div class="relative max-w-xs mx-auto">
              <input type="text" id="codeInput" maxlength="6" 
                     class="w-full px-6 py-5 rounded-xl bg-white/10 border-2 border-travel-olive text-white text-center text-3xl font-mono font-bold placeholder-white/60 focus:outline-none focus:border-travel-sand focus:bg-white/20 transition-all"
                     placeholder="000000">
              <div class="absolute -top-3 -right-3 w-8 h-8 bg-travel-olive rounded-full flex items-center justify-center">
                <i class="fas fa-check text-white text-sm"></i>
              </div>
            </div>
          </div>

          <div class="space-y-4">
            <button id="verifyBtn" onclick="verifierCode()" 
                    class="w-full bg-gradient-to-r from-travel-olive to-travel-teal text-white py-5 rounded-xl font-bold text-xl hover:shadow-travel-teal/30 transform hover:scale-[1.02] transition-all duration-300 shadow-xl backdrop-blur-sm flex items-center justify-center space-x-3">
              <i class="fas fa-check-circle text-xl"></i>
              <span>Vérifier et Activer</span>
            </button>

            <button onclick="retourInscription()" class="w-full glass px-6 py-3 rounded-xl text-white font-medium hover:bg-white/20 transition-all duration-300 flex items-center justify-center space-x-2">
              <i class="fas fa-arrow-left"></i>
              <span>Retour à l'inscription</span>
            </button>
          </div>
        </div>

        <!-- Links -->
        <div class="mt-10 text-center space-y-4 pt-8 border-t border-white/10">
          <p class="text-gray-200 text-lg">
            Déjà un compte ? 
            <a href="/login" class="text-travel-sand hover:text-travel-sunset font-semibold underline transition-colors ml-1">Connectez-vous</a>
          </p>
          <div class="flex items-center justify-center space-x-6 text-sm">
            <a href="/help" class="text-gray-300 hover:text-travel-sand transition-colors flex items-center space-x-1">
              <i class="fas fa-question-circle"></i>
              <span>Besoin d'aide ?</span>
            </a>
            <a href="/contact" class="text-gray-300 hover:text-travel-sand transition-colors flex items-center space-x-1">
              <i class="fas fa-phone"></i>
              <span>Contactez-nous</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
document.querySelector('form').addEventListener('submit', async e => {
  e.preventDefault();
  const data = Object.fromEntries(new FormData(e.target));
  
  const response = await fetch('/inscription', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify(data)
  });
  
  const result = await response.json();
  
  if (result.success) {
    // Redirect to verification page with email
    window.location.href = `/verification?email=${encodeURIComponent(data.email)}`;
  } else {
    alert('❌ ' + result.message);
  }
});
</script>
</body>
</html>
