<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connexion - Tunisie Authentique</title>
  {{#if isDevelopment}}
    <script src="https://cdn.tailwindcss.com"></script>
  {{else}}
    <link rel="stylesheet" href="/css/style.css">
  {{/if}}
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>
<body class="flex items-center justify-center p-4">
  <!-- Background Hero Fullscreen -->
  <div class="fixed inset-0 z-0">
    <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1950&q=80" 
         alt="Tropical Beach" class="w-full h-full object-cover">
    <div class="absolute inset-0 bg-gradient-to-b from-purple-900/80 to-blue-900/80"></div>
  </div>

  <!-- Main Content Centré -->
  <div class="relative z-10 flex items-center justify-center min-h-screen px-4">
    <div class="w-full max-w-md">
      <!-- Login Form Glass -->
      <div class="glass rounded-3xl p-8 shadow-2xl backdrop-blur-xl">
        <div class="text-center mb-8">
          <h1 class="text-4xl font-black text-white mb-2">CONNEXION</h1>
          <p class="text-xl text-white/90">Tunisie Authentique</p>
        </div>

        <!-- Error Message -->
        {{#if error}}
          <div class="bg-red-500/20 border border-red-500 text-red-100 px-4 py-3 rounded-xl mb-6 backdrop-blur-sm">
            <div class="flex items-center">
              <i class="fas fa-exclamation-triangle mr-3 text-xl"></i>
              <span class="font-medium">{{error}}</span>
            </div>
          </div>
        {{/if}}

        <!-- Login Form -->
        <form method="POST" action="/login" class="space-y-6">
          <!-- Email -->
          <div class="group">
            <label class="block text-white font-semibold mb-3 text-lg">Email Address</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                <i class="fas fa-envelope text-gray-400 group-focus-within:text-yellow-400 transition-colors"></i>
              </div>
              <input type="email" name="email" required
                     class="w-full pl-12 pr-4 py-4 rounded-xl bg-white/20 border-2 border-white/30 text-white placeholder-white/70 focus:outline-none focus:border-yellow-400 focus:bg-white/30 focus:ring-2 focus:ring-yellow-400/50 transition-all text-lg"
                     placeholder="john.doe@example.com"
                     value="{{email}}">
            </div>
          </div>

          <!-- Password -->
          <div class="group">
            <label class="block text-white font-semibold mb-3 text-lg">Password</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                <i class="fas fa-lock text-gray-400 group-focus-within:text-yellow-400 transition-colors"></i>
              </div>
              <input type="password" name="password" required
                     class="w-full pl-12 pr-4 py-4 rounded-xl bg-white/20 border-2 border-white/30 text-white placeholder-white/70 focus:outline-none focus:border-yellow-400 focus:bg-white/30 focus:ring-2 focus:ring-yellow-400/50 transition-all text-lg"
                     placeholder="•••••••">
            </div>
          </div>

          <!-- Submit -->
          <button type="submit" 
                  class="w-full bg-gradient-to-r from-orange-400 to-orange-500 text-white py-5 rounded-xl font-bold text-xl hover:from-orange-500 hover:to-orange-600 transform hover:scale-105 transition-all shadow-2xl backdrop-blur-sm">
            <i class="fas fa-sign-in-alt mr-3"></i>
            SE CONNECTER
          </button>
        </form>

        <!-- Links -->
        <div class="mt-8 text-center space-y-4 pt-6 border-t border-white/20">
          <p class="text-white/80 text-lg">
            Pas encore de compte ? 
            <a href="/inscription" class="text-yellow-400 font-semibold hover:text-yellow-300 underline transition-colors">S'inscrire</a>
          </p>
          <a href="/forgot-password" class="text-white/70 hover:text-white text-sm underline transition-colors">Mot de passe oublié ?</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
