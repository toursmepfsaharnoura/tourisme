<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Paiement abonnement</title>
    <!-- Lien vers Bootstrap (si vous l'utilisez) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .payment-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            max-width: 500px;
            width: 100%;
            margin: 20px;
        }
        .card-header {
            background: #4e73df;
            color: white;
            padding: 20px;
            border-radius: 15px 15px 0 0;
            text-align: center;
        }
        .card-header h4 {
            margin: 0;
            font-weight: 600;
        }
        .card-body {
            padding: 30px;
        }
        .form-label {
            color: #333;
            font-weight: 500;
            margin-bottom: 5px;
        }
        .form-control {
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            padding: 12px;
            transition: border-color 0.3s;
        }
        .form-control:focus {
            border-color: #4e73df;
            box-shadow: none;
        }
        .btn-pay {
            background: #4e73df;
            color: white;
            border: none;
            padding: 14px;
            font-size: 18px;
            font-weight: 600;
            border-radius: 8px;
            width: 100%;
            transition: background 0.3s;
        }
        .btn-pay:hover {
            background: #2e59d9;
        }
        .btn-pay:disabled {
            background: #b7b7b7;
        }
        .text-dark {
            color: #333 !important;
        }
        .loader {
            text-align: center;
            margin-top: 20px;
        }
        .loader .spinner-border {
            width: 3rem;
            height: 3rem;
        }
        .error {
            color: red;
            font-size: 0.9em;
            margin-top: 5px;
        }
    </style>
</head>
<body>
    <div class="payment-card">
        <div class="card-header">
            <h4>Paiement d'abonnement</h4>
        </div>
        <div class="card-body">
            <form method="POST" action="/guide/paiement" id="payment-form">
                <div class="mb-3">
                    <label for="cardNumber" class="form-label text-dark">Numéro de carte</label>
                    <input type="text" class="form-control" id="cardNumber" name="cardNumber" 
                           placeholder="1234 1234 1234 1234" maxlength="19" required>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="expiry" class="form-label text-dark">Date d'expiration</label>
                        <input type="text" class="form-control" id="expiry" name="expiry" 
                               placeholder="MM/AA" maxlength="5" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="cvc" class="form-label text-dark">CVC</label>
                        <input type="text" class="form-control" id="cvc" name="cvc" 
                               placeholder="123" maxlength="3" required>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="cardholder" class="form-label text-dark">Nom du titulaire</label>
                    <input type="text" class="form-control" id="cardholder" name="cardholder" 
                           placeholder="Jean Dupont" required>
                </div>
                <div class="mb-3">
                    <label for="phone" class="form-label text-dark">Numéro de téléphone</label>
                    <input type="tel" class="form-control" id="phone" name="phone" 
                           placeholder="12345678" required>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn-pay" id="pay-button">Payer 30 TND</button>
                </div>
            </form>
            <div id="loading" style="display:none;" class="loader">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Chargement...</span>
                </div>
                <p class="text-dark mt-2">Traitement du paiement...</p>
            </div>
        </div>
    </div>

    <script>
const form = document.getElementById('payment-form');

form.addEventListener('submit', function(e) {
    let valid = true;

    const cardInput = document.getElementById('cardNumber');
    const expiryInput = document.getElementById('expiry');
    const cvcInput = document.getElementById('cvc');

    const cardNumber = cardInput.value.trim();
    const expiry = expiryInput.value.trim();
    const cvc = cvcInput.value.trim();
    const phoneInput = document.getElementById('phone');
    const phone = phoneInput.value.trim();

    // Reset style
    cardInput.style.border = "2px solid #e0e0e0";
    expiryInput.style.border = "2px solid #e0e0e0";
    cvcInput.style.border = "2px solid #e0e0e0";

    // =========================
    // 🔴 CARD NUMBER
    // =========================
    if (!/^[0-9 ]+$/.test(cardNumber)) {
        alert("❌ Numéro de carte invalide (chiffres فقط)");
        cardInput.style.border = "2px solid red";
        cardInput.focus();
        valid = false;
    } else if (cardNumber.replace(/\s/g, '').length !== 16) {
        alert("❌ Le numéro de carte doit contenir 16 chiffres");
        cardInput.style.border = "2px solid red";
        cardInput.focus();
        valid = false;
    }

    // =========================
    // 🔴 EXPIRY DATE
    // =========================
    if (valid) {
        const match = expiry.match(/^(0[1-9]|1[0-2])\/(\d{2})$/);

        if (!match) {
            alert("❌ Format invalide (MM/AA)");
            expiryInput.style.border = "2px solid red";
            expiryInput.focus();
            valid = false;
        } else {
            const month = parseInt(match[1]);
            const year = 2000 + parseInt(match[2]);

            const now = new Date();
            const expDate = new Date(year, month);

            if (expDate <= now) {
                alert("❌ La carte est expirée");
                expiryInput.style.border = "2px solid red";
                expiryInput.focus();
                valid = false;
            }
        }
    }

    // =========================
    // 🔴 CVC
    // =========================
    if (valid) {
        if (!/^[0-9]{3}$/.test(cvc)) {
            alert("❌ CVC invalide (3 chiffres requis)");
            cvcInput.style.border = "2px solid red";
            cvcInput.focus();
            valid = false;
        }
    }
    // =========================
// 🔴 PHONE
// =========================
if (valid) {
    if (!/^[0-9]{8}$/.test(phone)) {
        alert("❌ Numéro de téléphone invalide (8 chiffres requis)");
        phoneInput.style.border = "2px solid red";
        phoneInput.focus();
        valid = false;
    }
}

    // =========================
    // ❌ STOP SI ERREUR
    // =========================
    if (!valid) {
        e.preventDefault();
        return;
    }

    // =========================
    // ✅ OK → LOADER
    // =========================
    document.getElementById('pay-button').disabled = true;
    document.getElementById('loading').style.display = 'block';
});


// =========================
// FORMAT AUTO
// =========================

// Carte
document.getElementById('cardNumber').addEventListener('input', function(e) {
    let value = e.target.value.replace(/\D/g, '');
    let formatted = value.match(/.{1,4}/g)?.join(' ') || '';
    e.target.value = formatted;
});

// Expiry
document.getElementById('expiry').addEventListener('input', function(e) {
    let value = e.target.value.replace(/\D/g, '');
    if (value.length >= 2) {
        value = value.slice(0,2) + '/' + value.slice(2,4);
    }
    e.target.value = value;
});
</script>
</body>
</html>