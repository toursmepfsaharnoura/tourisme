<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Conversation avec l'Admin</title>
  <script src="/socket.io/socket.io.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    /* Hide main navbar */
    nav, header, .navbar, .navigation, .main-navbar, .top-nav {
      display: none !important;
    }
    
    body {
      padding-top: 0 !important;
      margin-top: 0 !important;
    }
    
    .message-container {
      max-height: calc(100vh - 200px);
      overflow-y: auto;
      scroll-behavior: smooth;
    }
    
    .message-bubble {
      max-width: 70%;
      word-wrap: break-word;
    }
    
    .message-sent {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      margin-left: auto;
    }
    
    .message-received {
      background: #f3f4f6;
      color: #1f2937;
      border: 1px solid #e5e7eb;
    }
    
    .typing-indicator {
      display: inline-block;
      padding: 8px 12px;
      background: #f3f4f6;
      border-radius: 18px;
      color: #6b7280;
    }
    
    .typing-indicator span {
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #9ca3af;
      margin: 0 2px;
      animation: typing 1.4s infinite;
    }
    
    .typing-indicator span:nth-child(2) {
      animation-delay: 0.2s;
    }
    
    .typing-indicator span:nth-child(3) {
      animation-delay: 0.4s;
    }
    
    @keyframes typing {
      0%, 60%, 100% {
        transform: translateY(0);
      }
      30% {
        transform: translateY(-10px);
      }
    }
    
    .online-indicator {
      width: 10px;
      height: 10px;
      background: #10b981;
      border-radius: 50%;
      border: 2px solid white;
      position: absolute;
      bottom: 0;
      right: 0;
    }
    
    .message-time {
      font-size: 0.75rem;
      opacity: 0.7;
    }
  </style>
</head>

<body class="bg-gray-50">
  <!-- Header -->
  <header class="bg-white shadow-sm border-b">
    <div class="container mx-auto px-4 py-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <a href="/guide/dashboard" class="text-gray-600 hover:text-gray-900">
            <i class="fas fa-arrow-left"></i>
          </a>
          <div class="flex items-center space-x-3">
            <div class="relative">
              <img src="/images/admin-avatar.png" alt="Admin" class="w-10 h-10 rounded-full">
              <div class="online-indicator"></div>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Administrateur</h3>
              <p class="text-sm text-green-600">En ligne</p>
            </div>
          </div>
        </div>
        <div class="flex items-center space-x-2">
          <span class="text-sm text-gray-500">{{user.nom_complet}}</span>
          <a href="/guide/dashboard" class="text-gray-600 hover:text-gray-900">
            <i class="fas fa-home"></i>
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- Messages Container -->
  <main class="container mx-auto px-4 py-4">
    <div class="bg-white rounded-lg shadow-lg">
      <div class="message-container p-4 space-y-4" id="messagesContainer">
        {{#if messages.length}}
          {{#each messages}}
            <div class="flex {{#if (eq this.id_expediteur ../user.id)}}justify-end{{else}}justify-start{{/if}}">
              <div class="message-bubble rounded-2xl px-4 py-2 shadow-sm
                {{#if (eq this.id_expediteur ../user.id)}}message-sent{{else}}message-received{{/if}}">
                <p class="text-sm">{{this.contenu}}</p>
                <div class="message-time mt-1">
                  {{formatTime this.date_creation}}
                  {{#if (eq this.id_expediteur ../user.id)}}
                    {{#if this.est_lu}}
                      <i class="fas fa-check-double text-blue-400 ml-1"></i>
                    {{else}}
                      <i class="fas fa-check text-gray-400 ml-1"></i>
                    {{/if}}
                  {{/if}}
                </div>
              </div>
            </div>
          {{/each}}
        {{else}}
          <div class="text-center py-8">
            <i class="fas fa-comments text-4xl text-gray-300 mb-3"></i>
            <p class="text-gray-500">Aucun message dans cette conversation</p>
            <p class="text-sm text-gray-400 mt-2">Envoyez votre premier message à l'administrateur</p>
          </div>
        {{/if}}
      </div>

      <!-- Message Input -->
      <div class="border-t p-4 bg-gray-50">
        <form id="messageForm" class="flex items-center space-x-2">
          <div class="flex-1 relative">
            <input 
              type="text" 
              id="messageInput" 
              name="contenu"
              placeholder="Tapez votre message..." 
              class="w-full px-4 py-3 border border-gray-300 rounded-full focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              autocomplete="off"
            >
            <button type="button" class="absolute right-2 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-gray-600">
              <i class="fas fa-paperclip"></i>
            </button>
          </div>
          <button 
            type="submit" 
            id="sendButton"
            class="bg-blue-600 text-white px-6 py-3 rounded-full hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed transition-all"
          >
            <i class="fas fa-paper-plane"></i>
          </button>
        </form>
        
        <!-- Typing Indicator -->
        <div id="typingIndicator" class="hidden mt-2">
          <div class="typing-indicator">
            <span></span>
            <span></span>
            <span></span>
            <span class="ml-2">L'admin est en train d'écrire...</span>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    const socket = io();
    const guideId = {{user.id}};
    const adminId = {{admin.id}};
    let lastMessageId = {{#if messages.length}}{{messages.[0].id}}{{else}}0{{/if}};

    // Join guide room
    socket.emit('joinGuide', guideId);
    
    // Scroll to bottom on load
    window.addEventListener('load', () => {
      scrollToBottom();
    });

    // Send message
    document.getElementById('messageForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const input = document.getElementById('messageInput');
      const content = input.value.trim();
      
      if (!content) return;
      
      const sendButton = document.getElementById('sendButton');
      sendButton.disabled = true;
      sendButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
      
      try {
        const response = await fetch('/guide/send-message', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            contenu: content,
            isResponse: true,
            type_message: 'TEXT'
          })
        });
        
        const result = await response.json();
        
        if (result.success) {
          input.value = '';
          // Ajouter immédiatement le message à la conversation
          addMessageToChat({
            content: content,
            date: new Date(),
            id: result.messageId || Date.now()
          }, true);
          scrollToBottom();
        } else {
          alert('Erreur: ' + result.message);
        }
      } catch (error) {
        console.error('Error sending message:', error);
        alert('Erreur de connexion. Veuillez réessayer.');
      } finally {
        sendButton.disabled = false;
        sendButton.innerHTML = '<i class="fas fa-paper-plane"></i>';
      }
    });

    // Listen for new messages from admin
    socket.on('guide_message', (data) => {
      if (data.from === 'admin') {
        addMessageToChat(data, false);
        scrollToBottom();
        
        // Mark message as read
        fetch('/guide/mark-read', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messageId: data.id })
        });
      }
    });

    // Listen for typing indicators
    socket.on('admin_typing', (isTyping) => {
      const indicator = document.getElementById('typingIndicator');
      if (isTyping) {
        indicator.classList.remove('hidden');
      } else {
        indicator.classList.add('hidden');
      }
    });

    // Send typing indicator
    let typingTimeout;
    document.getElementById('messageInput').addEventListener('input', () => {
      socket.emit('guide_typing', true);
      
      clearTimeout(typingTimeout);
      typingTimeout = setTimeout(() => {
        socket.emit('guide_typing', false);
      }, 1000);
    });

    function addMessageToChat(message, isSent) {
      const container = document.getElementById('messagesContainer');
      const messageDiv = document.createElement('div');
      
      const messageClass = isSent ? 'justify-end' : 'justify-start';
      const bubbleClass = isSent ? 'message-sent' : 'message-received';
      
      messageDiv.className = `flex ${messageClass}`;
      messageDiv.innerHTML = `
        <div class="message-bubble rounded-2xl px-4 py-2 shadow-sm ${bubbleClass}">
          <p class="text-sm">${message.content}</p>
          <div class="message-time mt-1">
            ${new Date(message.date).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })}
            ${isSent ? '<i class="fas fa-check text-gray-400 ml-1"></i>' : ''}
          </div>
        </div>
      `;
      
      container.appendChild(messageDiv);
    }

    function scrollToBottom() {
      const container = document.getElementById('messagesContainer');
      container.scrollTop = container.scrollHeight;
    }

    // Helper for formatting time (if not available in Handlebars)
    function formatTime(dateString) {
      const date = new Date(dateString);
      return date.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    }
  </script>
</body>
</html>
