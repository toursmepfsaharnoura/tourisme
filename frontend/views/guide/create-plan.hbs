<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Créer un Plan - Inside Tunisia</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50">
  <!-- Navigation -->
  {{> navbar}}
  
  <div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-3xl font-bold text-gray-900 mb-8">Créer un nouveau plan</h1>
      
      {{#if success}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-6">
          {{success}}
        </div>
      {{/if}}

      {{#if error}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
          {{error}}
        </div>
      {{/if}}

      <form action="/guide/create-plan" method="POST" enctype="multipart/form-data" class="bg-white shadow-md rounded px-8 pt-6 pb-8 mb-4">
        <div class="mb-6">
          <label class="block text-gray-700 text-sm font-bold mb-2" for="titre">
            Titre du plan *
          </label>
          <input 
            class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" 
            id="titre" 
            name="titre" 
            type="text" 
            placeholder="Ex: Circuit Sud Tunisien"
            value="{{#if formData}}{{formData.titre}}{{/if}}"
            required
          >
        </div>

        <div class="mb-6">
          <label class="block text-gray-700 text-sm font-bold mb-2" for="description">
            Description *
          </label>
          <textarea 
            class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" 
            id="description" 
            name="description" 
            rows="4"
            placeholder="Décrivez votre plan touristique..."
            required
          >{{#if formData}}{{formData.description}}{{/if}}</textarea>
        </div>

        <div class="mb-6">
          <label class="block text-gray-700 text-sm font-bold mb-2" for="prix">
            Prix (TND) *
          </label>
          <input 
            class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" 
            id="prix" 
            name="prix" 
            type="number" 
            min="0"
            step="0.01"
            placeholder="250"
            value="{{#if formData}}{{formData.prix}}{{/if}}"
            required
          >
        </div>

        <div class="mb-6">
          <label class="block text-gray-700 text-sm font-bold mb-2" for="max_participants">
            Nombre maximum de participants *
          </label>
          <input 
            class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" 
            id="max_participants" 
            name="max_participants" 
            type="number" 
            min="1"
            max="100"
            placeholder="20"
            value="{{#if formData}}{{formData.max_participants}}{{else}}20{{/if}}"
            required
          >
          <p class="text-xs text-gray-600 mt-2">Nombre maximum de participants pour ce plan</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
          <div>
            <label class="block text-gray-700 text-sm font-bold mb-2" for="date_debut">
              Date de début *
            </label>
            <input 
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" 
              id="date_debut" 
              name="date_debut" 
              type="date"
              value="{{#if formData}}{{formData.date_debut}}{{/if}}"
              required
              onchange="validateDates()"
            >
            <p class="text-xs text-gray-600 mt-2">La date de début doit être aujourd'hui ou dans le futur</p>
          </div>
          
          <div>
            <label class="block text-gray-700 text-sm font-bold mb-2" for="date_fin">
              Date de fin *
            </label>
            <input 
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" 
              id="date_fin" 
              name="date_fin" 
              type="date"
              value="{{#if formData}}{{formData.date_fin}}{{/if}}"
              required
              onchange="validateDates()"
            >
            <p class="text-xs text-gray-600 mt-2">La date de fin doit être après la date de début</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
          <div>
            <label class="block text-gray-700 text-sm font-bold mb-2" for="id_gouvernorat">
              Gouvernorat principal *
            </label>
            <select 
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" 
              id="id_gouvernorat" 
              name="id_gouvernorat" 
              required
            >
              <option value="">Sélectionner un gouvernorat</option>
              {{#each governorates}}
                <option value="{{this.id}}" {{#if formData}}{{#eq formData.id_gouvernorat this.id}}selected{{/eq}}{{/if}}>
                  {{this.nom}}
                </option>
              {{/each}}
            </select>
          </div>
          
          <div>
            <label class="block text-gray-700 text-sm font-bold mb-2" for="id_delegation">
              Délégation principale *
            </label>
            <select 
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" 
              id="id_delegation" 
              name="id_delegation" 
              required
            >
              <option value="">Sélectionner d'abord un gouvernorat</option>
            </select>
          </div>
        </div>

        <div class="mb-6">
          <label class="block text-gray-700 text-sm font-bold mb-2" for="image">
            Image du plan
          </label>
          <input 
            class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" 
            id="image" 
            name="image" 
            type="file"
            accept="image/*"
          >
          <p class="text-xs text-gray-600 mt-2">Formats acceptés: JPG, PNG, GIF (Max 5MB)</p>
        </div>

        <div class="mb-6">
          <label class="block text-gray-700 text-sm font-bold mb-2" for="lieux">
            Lieux à visiter *
          </label>
          <select 
            class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" 
            id="lieux" 
            name="lieux[]" 
            multiple
            size="6"
            required
          >
            {{#each delegations}}
              <option value="{{this.id}}">{{this.nom}} ({{this.gouvernorat_nom}})</option>
            {{/each}}
          </select>
          <p class="text-xs text-gray-600 mt-2">Maintenez Ctrl (ou Cmd) pour sélectionner plusieurs délégations</p>
        </div>

        <div class="flex items-center justify-between">
          <button 
            class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline" 
            type="submit"
            onclick="return validateForm(event)"
          >
            Créer le plan
          </button>
          
          <a 
            href="/guide/plans" 
            class="inline-block align-baseline font-bold text-sm text-blue-500 hover:text-blue-800"
          >
            Annuler
          </a>
        </div>
      </form>
    </div>
  </div>

  <!-- Footer -->
  {{> footer}}

  <script>
    // Fonction pour parser les dates
    function parseDate(dateString) {
      if (!dateString) return null;
      if (dateString.includes('-')) {
        return new Date(dateString);
      }
      const parts = dateString.split('/');
      if (parts.length === 3) {
        return new Date(parts[2], parts[1] - 1, parts[0]);
      }
      return null;
    }
    
    function validateDates() {
      const dateDebut = document.getElementById('date_debut');
      const dateFin = document.getElementById('date_fin');
      const debut = parseDate(dateDebut.value);
      const fin = parseDate(dateFin.value);
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      
      dateDebut.setCustomValidity('');
      dateFin.setCustomValidity('');
      
      if (dateDebut.value && debut) {
        if (debut < today) {
          dateDebut.setCustomValidity('La date de début doit être aujourd\'hui ou dans le futur');
          return false;
        }
      }
      
      if (dateFin.value && fin && debut) {
        if (fin <= debut) {
          dateFin.setCustomValidity('La date de fin doit être strictement après la date de début');
          return false;
        }
      }
      
      if (dateDebut.value) {
        dateFin.min = dateDebut.value;
      }
      
      return true;
    }
    
    function validateForm(event) {
      event.preventDefault();
      
      if (!validateDates()) {
        return false;
      }
      
      const form = event.target.closest('form');
      const requiredFields = [
        'titre', 'description', 'prix', 'max_participants', 
        'date_debut', 'date_fin', 'id_gouvernorat', 'id_delegation'
      ];
      
      const missingFields = [];
      
      requiredFields.forEach(fieldId => {
        const element = document.getElementById(fieldId);
        const value = element ? element.value.trim() : '';
        
        if (!value || value === '' || value === 'Sélectionner un gouvernorat' || value === 'Sélectionner d\'abord un gouvernorat') {
          missingFields.push(fieldId);
        }
      });
      
      const lieuxSelect = document.getElementById('lieux');
      const selectedLieux = lieuxSelect ? Array.from(lieuxSelect.selectedOptions).filter(option => option.value).map(option => option.value) : [];
      
      if (selectedLieux.length === 0) {
        missingFields.push('lieux');
      }
      
      if (missingFields.length > 0) {
        alert('Veuillez remplir les champs obligatoires: ' + missingFields.join(', '));
        return false;
      }
      
      console.log('Validation passed, submitting form...');
      form.submit();
    }
    
  document.addEventListener('DOMContentLoaded', function() {
  const dateDebut = document.getElementById('date_debut');
  const dateFin = document.getElementById('date_fin');
  const gouvernoratSelect = document.getElementById('id_gouvernorat');
  const delegationSelect = document.getElementById('id_delegation');

  const today = new Date().toISOString().split('T')[0];
  if (dateDebut) dateDebut.min = today;
  if (dateFin) dateFin.min = today;

  const delegationsData = {{{json delegations}}};

  if (gouvernoratSelect) {
    gouvernoratSelect.addEventListener('change', function() {
      const selectedGovernoratId = this.value;

      delegationSelect.innerHTML = '<option value="">Sélectionner une délégation</option>';

      if (selectedGovernoratId) {
        const filtered = delegationsData.filter(d =>
          d.id_gouvernorat == selectedGovernoratId
        );

        filtered.forEach(d => {
          const option = document.createElement('option');
          option.value = d.id;
          option.textContent = d.nom;
          delegationSelect.appendChild(option);
        });
      }
    });
  }
});
  
  </script>
</body>
</html>
