<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Créer un Plan - Inside Tunisia</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600;700&display=swap');
    body { font-family: 'Inter', sans-serif; }
    .font-playfair { font-family: 'Playfair Display', serif; }
    .desert-gradient { background: linear-gradient(135deg, #f59e0b, #dc2626); }
    .ocean-gradient { background: linear-gradient(135deg, #0891b2, #0e7490); }
  </style>
</head>
<body class="bg-gray-50">
  <!-- Navigation -->
  {{> navbar}}
  
  <!-- Hero Section -->
  <section class="relative h-64 flex items-center justify-center bg-cover bg-center" style="background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1950&q=80');">
    <div class="relative z-10 text-center text-white px-4 max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 font-playfair">Créer un Plan Touristique</h1>
      <p class="text-lg text-gray-200 max-w-2xl mx-auto">
        Concevez une expérience unique pour les visiteurs de la Tunisie
      </p>
    </div>
  </section>

  <!-- Form Section -->
  <section class="py-16 px-4 max-w-4xl mx-auto">
    <div class="bg-white rounded-2xl shadow-xl p-8">
      {{#if success}}
        <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg mb-6">
          <div class="flex items-center">
            <i class="fas fa-check-circle mr-2"></i>
            <span>{{success}}</span>
          </div>
        </div>
      {{/if}}

      {{#if error}}
        <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg mb-6">
          <div class="flex items-center">
            <i class="fas fa-exclamation-circle mr-2"></i>
            <span>{{error}}</span>
          </div>
        </div>
      {{/if}}

      <form action="/guide/create-plan" method="POST" class="space-y-6">
        <!-- Basic Information -->
        <div class="border-b pb-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 font-playfair">Informations générales</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="titre" class="block text-sm font-medium text-gray-700 mb-2">
                Titre du plan <span class="text-red-500">*</span>
              </label>
              <input 
                type="text" 
                id="titre" 
                name="titre" 
                placeholder="Ex: Circuit Sud Tunisien" 
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              >
            </div>
            
            <div>
              <label for="prix" class="block text-sm font-medium text-gray-700 mb-2">
                Prix (TND) <span class="text-red-500">*</span>
              </label>
              <input 
                type="number" 
                id="prix" 
                name="prix" 
                placeholder="250" 
                min="0" 
                step="0.01" 
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              >
            </div>
          </div>
          <div class="mt-6">
            <label for="capacite_max" class="block text-sm font-medium text-gray-700 mb-2">
              Nombre maximal de personnes <span class="text-red-500">*</span>
            </label>
            <input
              type="number"
              id="capacite_max"
              name="capacite_max"
              placeholder="20"
              min="1"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            >
          </div>
          
          <div class="mt-6">
            <label for="description" class="block text-sm font-medium text-gray-700 mb-2">
              Description <span class="text-red-500">*</span>
            </label>
            <textarea 
              id="description" 
              name="description" 
              placeholder="Décrivez votre plan touristique en détail..." 
              rows="4" 
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            ></textarea>
          </div>
        </div>

        <!-- Dates -->
        <div class="border-b pb-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 font-playfair">Période du voyage</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="date_debut" class="block text-sm font-medium text-gray-700 mb-2">
                Date de début <span class="text-red-500">*</span>
              </label>
              <input 
                type="date" 
                id="date_debut" 
                name="date_debut" 
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              >
            </div>
            
            <div>
              <label for="date_fin" class="block text-sm font-medium text-gray-700 mb-2">
                Date de fin <span class="text-red-500">*</span>
              </label>
              <input 
                type="date" 
                id="date_fin" 
                name="date_fin" 
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              >
            </div>
          </div>
        </div>

        <!-- Delegations -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6 font-playfair">Délégations à visiter</h2>
          
          {{#if delegations.length}}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {{#each delegations}}
                <label class="flex items-center p-4 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors">
                  <input 
                    type="checkbox" 
                    name="delegations[]" 
                    value="{{this.id}}" 
                    class="mr-3 w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500"
                  >
                  <div>
                    <div class="font-medium text-gray-900">{{this.nom}}</div>
                    <div class="text-sm text-gray-500">{{this.gouvernorat_nom}}</div>
                  </div>
                </label>
              {{/each}}
            </div>
            
            <p class="mt-4 text-sm text-gray-600">
              <i class="fas fa-info-circle mr-1"></i>
              Sélectionnez toutes les délégations que votre plan touristique inclura.
            </p>
          {{else}}
            <div class="text-center py-8 bg-gray-50 rounded-lg">
              <i class="fas fa-map-marked-alt text-gray-400 text-3xl mb-3"></i>
              <p class="text-gray-600">Aucune délégation disponible</p>
            </div>
          {{/if}}
        </div>

        <!-- Actions -->
        <div class="flex gap-4 pt-6">
          <button 
            type="submit" 
            class="flex-1 ocean-gradient text-white py-3 px-6 rounded-xl font-semibold hover:opacity-90 transition-opacity"
          >
            <i class="fas fa-plus-circle mr-2"></i>
            Créer le plan
          </button>
          
          <a 
            href="/guide/plans" 
            class="flex-1 bg-gray-200 text-gray-700 py-3 px-6 rounded-xl font-semibold hover:bg-gray-300 transition-colors text-center"
          >
            <i class="fas fa-arrow-left mr-2"></i>
            Retour
          </a>
        </div>
      </form>
    </div>
  </section>

  <!-- Footer -->
  {{> footer}}

  <script>
    // Date validation
    document.addEventListener('DOMContentLoaded', function() {
      const dateDebut = document.getElementById('date_debut');
      const dateFin = document.getElementById('date_fin');
      
      // Set minimum date to today
      const today = new Date().toISOString().split('T')[0];
      dateDebut.min = today;
      dateFin.min = today;
      
      // Update end date minimum when start date changes
      dateDebut.addEventListener('change', function() {
        dateFin.min = this.value;
        if (dateFin.value && dateFin.value < this.value) {
          dateFin.value = this.value;
        }
      });
    });
  </script>
</body>
</html>