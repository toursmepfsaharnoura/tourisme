<!-- Hero Section -->
<section class="relative h-96 flex items-center justify-center bg-cover bg-center" style="background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1950&q=80');">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/50"></div>
  <div class="relative z-10 text-center text-white px-4 max-w-4xl mx-auto">
    <div class="animate-slide-up">
      <h1 class="text-5xl md:text-6xl font-bold mb-6 text-shadow-glow font-playfair">
        {{gouvernorat.nom}}
      </h1>
      <p class="text-xl md:text-2xl text-gray-200 max-w-2xl mx-auto">
        Discover the amazing destinations and hidden gems of this beautiful region
      </p>
    </div>
  </div>
</section>

<!-- Breadcrumb -->
<section class="py-6 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4">
    <nav class="flex items-center space-x-2 text-sm">
      <a href="/" class="text-gray-600 hover:text-ocean-blue transition-colors">
        <i class="fas fa-home mr-2"></i>Accueil
      </a>
      <i class="fas fa-chevron-right text-gray-400"></i>
      <a href="/gouvernorats/1/delegations" class="text-gray-600 hover:text-ocean-blue transition-colors">
        Destinations
      </a>
      <i class="fas fa-chevron-right text-gray-400"></i>
      <span class="text-gray-900 font-medium">{{gouvernorat.nom}}</span>
    </nav>
  </div>
</section>

<!-- Delegations Section -->
<section class="py-20 bg-gradient-to-b from-gray-50 to-white">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4 font-playfair">
        Explore Delegations
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Discover the unique charm and attractions of each delegation in {{gouvernorat.nom}}
      </p>
    </div>
    
    {{#if delegations.length}}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {{#each delegations}}
        <div class="group cursor-pointer" onclick="window.location.href='/delegation/{{id}}'">
          <div class="relative overflow-hidden rounded-2xl card-hover">
            <!-- Delegation Image -->
            <div class="h-64 relative">
              {{#if image}}
                <img src="{{image}}" alt="{{nom}}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" referrerpolicy="no-referrer">
              {{else}}
                <div class="w-full h-full bg-gradient-to-br from-ocean-blue to-desert-orange flex items-center justify-center group-hover:scale-110 transition-transform duration-500">
                  <i class="fas fa-map-location-dot text-6xl text-white/30"></i>
                </div>
              {{/if}}
              <!-- Overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              
              <!-- Type Badge -->
              <div class="absolute top-4 left-4 bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full">
                <div class="flex items-center text-white text-sm">
                  <i class="fas fa-map-pin mr-1"></i>
                  <span>{{#if type}}{{type}}{{else}}DELEGATION{{/if}}</span>
                </div>
              </div>
              
              <!-- Rating Badge -->
              <div class="absolute bottom-4 left-4 bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full">
                <div class="flex items-center text-white text-sm">
                  <i class="fas fa-star text-yellow-400 mr-1"></i>
                  <span>4.7</span>
                </div>
              </div>
            </div>
            
            <!-- Content -->
            <div class="p-6 bg-white rounded-b-2xl shadow-lg">
              <h3 class="text-xl font-bold text-gray-900 mb-2">{{nom}}</h3>
              <p class="text-gray-600 text-sm mb-4">Experience the beauty of {{nom}}</p>
              <div class="flex items-center justify-between">
                <div class="flex items-center text-gray-500 text-sm">
                  <i class="fas fa-map-pin mr-2"></i>
                  <span>{{../gouvernorat.nom}}</span>
                </div>
                <div class="text-ocean-blue font-semibold">
                  Explore →
                </div>
              </div>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
    {{else}}
      <!-- No Delegations -->
      <div class="text-center py-16">
        <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <i class="fas fa-map text-gray-400 text-3xl"></i>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Delegations Coming Soon</h3>
        <p class="text-gray-600 mb-8 max-w-md mx-auto">
          We're working on cataloging all the amazing delegations in {{gouvernorat.nom}}. Check back soon!
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/" class="bg-ocean-blue hover:bg-ocean-dark text-white font-semibold py-3 px-6 rounded-xl transition-colors">
            <i class="fas fa-home mr-2"></i>
            Retour à l'accueil
          </a>
          <a href="/gouvernorats/1/delegations" class="desert-gradient text-white font-semibold py-3 px-6 rounded-xl transition-colors">
            <i class="fas fa-map-marked-alt mr-2"></i>
            Browse All Destinations
          </a>
        </div>
      </div>
    {{/if}}
  </div>
</section>

<!-- CTA Section -->
<section class="py-20 bg-gradient-to-r from-ocean-blue to-desert-orange relative overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute top-0 left-0 w-full h-full bg-black/20"></div>
    <div class="wave-animation absolute inset-0"></div>
  </div>
  
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 font-playfair">
      Ready to Explore {{gouvernorat.nom}}?
    </h2>
    <p class="text-xl text-white/90 mb-12 max-w-2xl mx-auto">
      Join our expert local guides and discover the authentic beauty and culture of this amazing region
    </p>
    
    <div class="flex flex-col sm:flex-row gap-6 justify-center">
      <a href="/guides" class="bg-white text-ocean-blue px-8 py-4 rounded-2xl font-bold text-lg shadow-2xl hover:scale-105 transition-transform duration-300">
        <i class="fas fa-user-tie mr-2"></i>
        Find Local Guides
      </a>
      <a href="/plans" class="bg-transparent border-2 border-white text-white px-8 py-4 rounded-2xl font-bold text-lg hover:bg-white hover:text-ocean-blue transition-all duration-300">
        <i class="fas fa-route mr-2"></i>
        View Tours
      </a>
    </div>
  </div>
</section>
