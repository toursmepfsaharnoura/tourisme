<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mes Réservations - Touriste</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    .glass {
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.25);
    }
    .card-hover {
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .card-hover:hover {
      transform: translateY(-10px) scale(1.02);
      box-shadow: 0 25px 50px rgba(0,0,0,0.3);
    }
  </style>
</head>
<body class="bg-gradient-to-br from-purple-900 via-blue-900 to-indigo-900 min-h-screen text-white">

  <!-- Hero Section -->
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-6xl font-black mb-4">
          Mes <span class="text-yellow-400">Réservations</span>
        </h1>
        <p class="text-xl opacity-90 max-w-2xl mx-auto">
          Suivez l'état de vos réservations de circuits touristiques
        </p>
      </div>
    </div>
  </section>

  <!-- Reservations List -->
  <section class="px-6 pb-32">
    <div class="max-w-7xl mx-auto">
      {{#if reservations.length}}
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {{#each reservations}}
        <div class="glass rounded-3xl p-8 card-hover border-2 border-white/20">
          <!-- Header -->
          <div class="flex items-start justify-between mb-6">
            <div>
              <h3 class="text-2xl font-black mb-2">{{plan.titre}}</h3>
              <p class="text-lg opacity-80">{{plan.description}}</p>
            </div>
            <div class="text-right">
              {{#if plan.prix}}
              <div class="text-2xl font-black text-yellow-400 mb-2">
                {{plan.prix}} TND
              </div>
              {{/if}}
              <div class="px-3 py-1 rounded-full text-sm font-semibold
                {{#eq statut 'EN_ATTENTE'}}bg-orange-500/20 text-orange-400 border border-orange-500/30
                {{else if (eq statut 'CONFIRMEE')}}bg-green-500/20 text-green-400 border border-green-500/30
                {{else}}bg-red-500/20 text-red-400 border border-red-500/30{{/eq}}">
                {{#eq statut 'EN_ATTENTE'}}En Attente de Confirmation
                {{else if (eq statut 'CONFIRMEE')}}Confirmée
                {{else}}Annulée{{/eq}}
              </div>
            </div>
          </div>

          <!-- Plan Details -->
          <div class="bg-white/10 rounded-2xl p-6 mb-6">
            <h4 class="text-lg font-bold mb-4 text-blue-400">
              <i class="fas fa-route mr-2"></i>
              Détails du Circuit
            </h4>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <p class="text-sm opacity-75">Date de début</p>
                <p class="font-semibold">{{formatDate plan.date_debut}}</p>
              </div>
              <div>
                <p class="text-sm opacity-75">Date de fin</p>
                <p class="font-semibold">{{formatDate plan.date_fin}}</p>
              </div>
            </div>
          </div>

          <!-- Reservation Details -->
          {{#if date_reservation}}
          <div class="bg-white/10 rounded-2xl p-6 mb-6">
            <h4 class="text-lg font-bold mb-4 text-green-400">
              <i class="fas fa-calendar-check mr-2"></i>
              Ma Réservation
            </h4>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <p class="text-sm opacity-75">Date souhaitée</p>
                <p class="font-semibold">{{formatDate date_reservation}}</p>
              </div>
              {{#if nombre_personnes}}
              <div>
                <p class="text-sm opacity-75">Nombre de personnes</p>
                <p class="font-semibold">{{nombre_personnes}}</p>
              </div>
              {{/if}}
              <div>
                <p class="text-sm opacity-75">Date de réservation</p>
                <p class="font-semibold">{{formatDate date_creation}}</p>
              </div>
            </div>
            {{#if message}}
            <div class="mt-4">
              <p class="text-sm opacity-75">Mon message</p>
              <p class="font-semibold italic">{{message}}</p>
            </div>
            {{/if}}
          </div>
          {{/if}}

          <!-- Actions -->
          {{#if (eq statut 'EN_ATTENTE')}}
          <div class="pt-6 border-t border-white/30">
            <div class="text-center mb-4">
              <i class="fas fa-clock text-orange-400 text-2xl mb-2"></i>
              <p class="text-lg font-semibold">En attente de confirmation du guide</p>
              <p class="text-sm opacity-75">Le guide examinera votre demande bientôt</p>
            </div>
            <div class="text-center">
              <button onclick="cancelReservation({{id}})" class="inline-flex items-center justify-center gap-2 rounded-2xl bg-gradient-to-r from-red-500 to-pink-600 px-8 py-4 font-bold text-white shadow-lg transition hover:scale-[1.01] hover:shadow-2xl">
                <i class="fas fa-times"></i>
                Annuler la réservation
              </button>
            </div>
          </div>
          {{else if (eq statut 'CONFIRMEE')}}
          <div class="text-center py-6 border-t border-white/30">
            <i class="fas fa-check-circle text-green-400 text-3xl mb-4"></i>
            <p class="text-xl font-bold text-green-400 mb-2">Réservation Confirmée !</p>
            <p class="text-lg opacity-80">Votre circuit est réservé. Le guide vous contactera bientôt pour les détails.</p>
          </div>
          {{else}}
          <div class="text-center py-6 border-t border-white/30">
            <i class="fas fa-times-circle text-red-400 text-3xl mb-4"></i>
            <p class="text-xl font-bold text-red-400 mb-2">Réservation Annulée</p>
            <p class="text-lg opacity-80">Cette réservation a été annulée.</p>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="text-center py-32">
        <i class="fas fa-calendar-times text-8xl text-white/20 mb-12"></i>
        <h2 class="text-4xl font-black mb-6">Aucune Réservation</h2>
        <p class="text-2xl opacity-80 mb-12 max-w-2xl mx-auto">
          Vous n'avez pas encore réservé de circuits touristiques
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/touriste/plans" class="glass px-12 py-6 rounded-3xl font-bold text-xl card-hover">
            <i class="fas fa-search mr-3"></i>
            Découvrir les Plans
          </a>
          <a href="/touriste/favorites" class="bg-gradient-to-r from-yellow-400 to-orange-500 px-12 py-6 rounded-3xl font-bold text-xl card-hover">
            <i class="fas fa-heart mr-3"></i>
            Voir mes Favoris
          </a>
        </div>
      </div>
      {{/if}}
    </div>
  </section>

  <script>    async function cancelReservation(reservationId) {
      if (confirm('Êtes-vous sûr de vouloir annuler cette réservation ?')) {
        try {
          const response = await fetch(`/touriste/reservations/${reservationId}/cancel`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            }
          });

          if (response.ok) {
            alert('Réservation annulée avec succès');
            location.reload();
          } else {
            alert('Erreur lors de l\'annulation');
          }
        } catch (error) {
          console.error('Error:', error);
          alert('Erreur lors de l\'annulation');
        }
      }
    }
  </script>

</body>
</html>