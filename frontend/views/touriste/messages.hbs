<!DOCTYPE html>
<html lang="fr">
<head>
    <title>Messages - Touriste</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .messages-header {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            color: white;
            padding: 20px 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            display: flex;
            align-items: center;
            gap: 15px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .messages-header a {
            font-size: 1.8em;
            color: white;
            text-decoration: none;
            transition: all 0.3s;
        }

        .messages-header a:hover {
            opacity: 0.8;
        }

        .touriste-info {
            flex: 1;
        }

        .touriste-name {
            font-size: 1.3em;
            margin-bottom: 5px;
        }

        .touriste-role {
            font-size: 0.9em;
            opacity: 0.8;
        }

        .messages-container {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            max-width: 800px;
            margin: 0 auto;
            width: 100%;
        }

        .guide-item {
            background: white;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 15px;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.08);
            text-decoration: none;
            color: inherit;
        }

        .guide-item:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.15);
        }

        .guide-avatar {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5em;
            font-weight: bold;
            flex-shrink: 0;
        }

        .guide-avatar img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
        }

        .guide-info {
            flex: 1;
        }

        .guide-name {
            font-size: 1.1em;
            font-weight: 600;
            color: #333;
            margin-bottom: 5px;
        }

        .guide-role {
            font-size: 0.9em;
            color: #666;
            margin-bottom: 8px;
        }

        .guide-meta {
            display: flex;
            align-items: center;
            gap: 15px;
            font-size: 0.85em;
            color: #999;
        }

        .last-message-time {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .unread-badge {
            background: #dc3545;
            color: white;
            border-radius: 12px;
            padding: 2px 8px;
            font-size: 0.75em;
            font-weight: bold;
            min-width: 20px;
            text-align: center;
        }

        .empty-messages {
            text-align: center;
            padding: 80px 20px;
            color: #999;
        }

        .empty-messages-icon {
            font-size: 4em;
            margin-bottom: 15px;
            color: #28a745;
        }

        .empty-messages-text {
            font-size: 1.2em;
            color: #666;
            margin-bottom: 10px;
        }

        .empty-messages-subtext {
            font-size: 0.9em;
            color: #999;
        }

        @media (max-width: 600px) {
            .messages-header { padding: 15px 20px; }
            .touriste-name { font-size: 1.1em; }
            .guide-item { padding: 15px; }
            .messages-container { padding: 10px; }
            .guide-avatar { width: 50px; height: 50px; }
        }
    </style>
</head>
<body>
    <!-- HEADER -->
    <div class="messages-header">
        <a href="/touriste/dashboard">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div class="touriste-info">
            <div class="touriste-name">
                <i class="fas fa-user"></i>
                {{user.nom_complet}}
            </div>
            <div class="touriste-role">Touriste</div>
        </div>
    </div>

    <!-- MESSAGES LIST -->
    <div class="messages-container">
        {{#if guides.length}}
            {{#each guides}}
                <a href="/touriste/chat/{{id}}" class="guide-item">
                    <div class="guide-avatar">
                        {{#if photo_profil}}
                            <img src="{{photo_profil}}" alt="{{nom_complet}}">
                        {{else}}
                            {{substring nom_complet 0 1}}
                        {{/if}}
                    </div>
                    <div class="guide-info">
                        <div class="guide-name">{{nom_complet}}</div>
                        <div class="guide-role">
                            <i class="fas fa-user-tie"></i> Guide touristique
                        </div>
                        <div class="guide-meta">
                            <div class="last-message-time">
                                <i class="fas fa-clock"></i>
                                {{#if last_message_date}}
                                    {{formatDate last_message_date}}
                                {{else}}
                                    Jamais
                                {{/if}}
                            </div>
                            {{#if unread_count}}
                                <div class="unread-badge">{{unread_count}}</div>
                            {{/if}}
                        </div>
                    </div>
                </a>
            {{/each}}
        {{else}}
            <div class="empty-messages">
                <div class="empty-messages-icon">
                    <i class="fas fa-comments"></i>
                </div>
                <div class="empty-messages-text">Aucune conversation</div>
                <div class="empty-messages-subtext">
                    Vous n'avez pas encore de conversations avec des guides.
                    <br>
                    Parcourez les guides et commencez une conversation !
                </div>
            </div>
        {{/if}}
    </div>

    <script>
        // Formatter la date
        function formatDate(dateString) {
            if (!dateString) return 'Jamais';
            
            const date = new Date(dateString);
            const now = new Date();
            const diff = now - date;
            
            if (diff < 60000) return 'À l\'instant';
            if (diff < 3600000) return `${Math.floor(diff / 60000)} min`;
            if (diff < 86400000) return `${Math.floor(diff / 3600000)} h`;
            if (diff < 604800000) return `${Math.floor(diff / 86400000)} j`;
            
            return date.toLocaleDateString('fr-FR', { 
                day: 'numeric', 
                month: 'short', 
                hour: '2-digit', 
                minute: '2-digit' 
            });
        }

        // Helper pour Handlebars
        if (typeof Handlebars !== 'undefined') {
            Handlebars.registerHelper('formatDate', formatDate);
            Handlebars.registerHelper('substring', function(str, start, length) {
                if (!str) return '';
                return str.substring(start, start + length);
            });
        }

        // Mettre à jour les dates affichées
        document.addEventListener('DOMContentLoaded', () => {
            // Mettre à jour les temps toutes les minutes
            setInterval(() => {
                const timeElements = document.querySelectorAll('.last-message-time');
                timeElements.forEach(element => {
                    const dateText = element.textContent.trim();
                    if (dateText && dateText !== 'Jamais') {
                        // Les dates sont formatées côté serveur, pas besoin de mise à jour automatique
                    }
                });
            }, 60000);
        });
    </script>
</body>
</html>
