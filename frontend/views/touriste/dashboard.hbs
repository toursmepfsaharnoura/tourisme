<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-sky-500 via-cyan-300 to-slate-100 opacity-40"></div>
  <div class="relative mx-auto max-w-7xl px-6 py-16">
    <div class="glass-morphism rounded-[2rem] border border-white/30 p-10 shadow-2xl">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-3xl">
          <p class="text-sm uppercase tracking-[0.35em] text-sky-700">Tableau de bord touriste</p>
          <h1 class="mt-4 text-4xl font-extrabold text-slate-900 sm:text-5xl">
            Bonjour, {{user.nom_complet}}.
          </h1>
          <p class="mt-4 max-w-xl text-lg leading-8 text-slate-600">
            Retrouvez ici tous les guides actifs, leurs circuits recommandés, et commandez votre prochain voyage avec un design moderne.
            Vous pouvez également laisser un avis en étoiles pour chaque guide après votre réservation.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-3xl bg-slate-900/90 p-6 text-white shadow-xl">
            <p class="text-sm uppercase tracking-[0.3em] text-slate-300">Guides</p>
            <p class="mt-4 text-3xl font-extrabold">{{guides.length}}</p>
          </div>
          <div class="rounded-3xl bg-slate-900/90 p-6 text-white shadow-xl">
            <p class="text-sm uppercase tracking-[0.3em] text-slate-300">Circuits</p>
            <p class="mt-4 text-3xl font-extrabold">{{plansCount}}</p>
          </div>
          <a href="/touriste/favorites" class="rounded-3xl bg-rose-600/90 p-6 text-white shadow-xl hover:bg-rose-700 transition text-center">
            <p class="text-sm uppercase tracking-[0.3em] text-rose-200">♥ Mes Favoris</p>
            <p class="mt-4 text-3xl font-extrabold"><i class="fas fa-heart"></i></p>
          </a>
          <a href="/touriste/reservations" class="rounded-3xl bg-blue-600/90 p-6 text-white shadow-xl hover:bg-blue-700 transition text-center">
            <p class="text-sm uppercase tracking-[0.3em] text-sky-200">📅 Mes Réservations</p>
            <p class="mt-4 text-3xl font-extrabold">{{reservations.length}}</p>
          </a>
        </div>
        <a href="/logout" class="mt-6 inline-flex items-center gap-2 rounded-3xl bg-red-600 hover:bg-red-700 px-6 py-3 text-white font-semibold transition shadow-lg">
          <i class="fas fa-sign-out-alt"></i>
          Déconnexion
        </a>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 py-8">
  <!-- Favorites Section -->
  <div class="mb-16 rounded-[2rem] border-2 border-rose-300/60 bg-gradient-to-r from-rose-50 to-red-50 p-8 shadow-lg">
    <div class="flex items-center justify-between">
      <div>
        <h2 class="text-3xl font-bold text-slate-900 flex items-center gap-3">
          <i class="fas fa-heart text-rose-600"></i>
          Vos Plans Favoris
        </h2>
        <p class="mt-2 text-slate-600">Accédez rapidement à tous les circuits que vous avez enregistrés</p>
      </div>
      <a href="/touriste/favorites" class="rounded-3xl bg-rose-600 hover:bg-rose-700 px-6 py-3 text-white font-semibold transition shadow-lg">
        <i class="fas fa-arrow-right mr-2"></i>
        Voir tous
      </a>
    </div>
  </div>

  <!-- Reservations Section -->
  <div class="mb-16 rounded-[2rem] border-2 border-blue-300/60 bg-gradient-to-r from-blue-50 to-cyan-50 p-8 shadow-lg">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <h2 class="text-3xl font-bold text-slate-900 flex items-center gap-3">
          <i class="fas fa-calendar-check text-blue-600"></i>
          Mes Réservations
        </h2>
        <p class="mt-2 text-slate-600">Suivez l'état de vos réservations de circuits touristiques</p>
      </div>
      <a href="/touriste/reservations" class="rounded-3xl bg-blue-600 hover:bg-blue-700 px-6 py-3 text-white font-semibold transition shadow-lg inline-flex items-center gap-2">
        <i class="fas fa-arrow-right"></i>
        Voir toutes
      </a>
    </div>

    {{#if reservations.length}}
    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      {{#each reservations}}
      <div class="rounded-[2rem] bg-white/90 p-6 shadow-xl border border-slate-200">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-sm text-slate-500">{{plan.titre}}</p>
            <h3 class="mt-2 text-2xl font-bold text-slate-900">{{plan.titre}}</h3>
          </div>
          <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700">
            {{#eq statut 'EN_ATTENTE'}}En attente{{else if (eq statut 'CONFIRMEE')}}Confirmée{{else}}Annulée{{/eq}}
          </span>
        </div>

        <div class="mt-6 grid gap-4 sm:grid-cols-2 text-slate-700">
          <div>
            <p class="text-sm uppercase tracking-[0.2em] text-slate-400">Date souhaitée</p>
            <p class="mt-2 font-semibold">{{date_reservation}}</p>
          </div>
          <div>
            <p class="text-sm uppercase tracking-[0.2em] text-slate-400">Personnes</p>
            <p class="mt-2 font-semibold">{{nombre_personnes}}</p>
          </div>
        </div>

        <div class="mt-6 flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
          <div class="text-slate-500 text-sm">
            <p>Date de réservation : {{date_creation}}</p>
          </div>
          {{#eq statut 'EN_ATTENTE'}}
          <button onclick="cancelReservation({{id}})" class="w-full lg:w-auto rounded-3xl bg-red-500 px-5 py-3 font-semibold text-white transition hover:bg-red-600">
            <i class="fas fa-times mr-2"></i>
            Annuler
          </button>
          {{/eq}}
        </div>
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="mt-8 rounded-[2rem] bg-white/90 p-8 shadow-xl border border-slate-200 text-slate-700">
      <p class="text-lg font-semibold">Aucune réservation récente.</p>
      <p class="mt-3">Réservez un circuit pour voir vos réservations ici.</p>
    </div>
    {{/if}}
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-16">
  {{#if guides.length}}
    <div class="space-y-14">
      {{#each guides}}
        <div class="rounded-[2rem] border border-slate-200/70 bg-white/90 p-8 shadow-xl">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div class="flex items-center gap-4">
              {{#if photo_profil}}
                <img src="{{photo_profil}}" alt="Photo de {{nom}}" class="h-24 w-24 rounded-full object-cover border-4 border-sky-500/80 shadow-lg" />
              {{else}}
                <div class="flex h-24 w-24 items-center justify-center rounded-full bg-sky-500 text-3xl font-black text-white shadow-lg">
                  {{substring nom 0 1}}
                </div>
              {{/if}}
              <div>
                <p class="text-sm uppercase tracking-[0.3em] text-slate-500">Guide</p>
                <h2 class="text-3xl font-extrabold text-slate-900">{{nom}}</h2>
                <p class="mt-1 text-sm text-slate-600">{{email}}</p>
              </div>
            </div>
            <div class="flex flex-col items-start gap-3 sm:items-end">
              <div class="rounded-3xl bg-slate-950/95 px-5 py-4 text-white shadow-lg">
                <p class="text-sm uppercase tracking-[0.25em] text-slate-300">Note moyenne</p>
                <p class="mt-2 text-3xl font-extrabold">{{avis.moyenne}} <span class="text-slate-400 text-base">/ 5</span></p>
                <p class="text-sm text-slate-400">{{avis.total}} avis</p>
              </div>
            </div>
          </div>

          <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {{#each plans}}
              <article class="glass-morphism rounded-[2rem] border border-slate-200/40 p-6 shadow-lg">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h3 class="text-2xl font-bold text-slate-900">{{titre}}</h3>
                    <p class="mt-2 text-sm text-slate-500">{{description}}</p>
                  </div>
                  <span class="rounded-2xl bg-sky-100 px-4 py-2 text-sm font-semibold text-sky-700">{{prix}} TND</span>
                </div>

                <div class="mt-6 grid gap-3 text-sm text-slate-600">
                  <div class="flex items-center gap-2">
                    <i class="fas fa-calendar-day text-sky-500"></i>
                    <span>Départ : {{formatDate date_debut}}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <i class="fas fa-calendar-check text-emerald-500"></i>
                    <span>Retour : {{formatDate date_fin}}</span>
                  </div>
                  {{#if delegations}}
                    <div class="flex items-start gap-2">
                      <i class="fas fa-map-marker-alt text-orange-500 mt-1"></i>
                      <p>Zones : {{delegations}}</p>
                    </div>
                  {{/if}}
                </div>

                <div class="mt-7 space-y-4">
                  <form method="POST" action="/reservations/touriste/reservations" class="space-y-4 rounded-3xl bg-slate-950/5 p-4">
                    <input type="hidden" name="id_plan" value="{{id}}" />
                    <div class="grid gap-3 sm:grid-cols-2">
                      <label class="block text-sm font-semibold text-slate-700">Date réservation</label>
                      <input type="date" name="date_reservation" required class="w-full rounded-2xl border border-slate-200 bg-white/90 px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-sky-500 focus:outline-none" />
                      <label class="block text-sm font-semibold text-slate-700">Personnes</label>
                      <input type="number" name="nombre_personnes" min="1" value="1" required class="w-full rounded-2xl border border-slate-200 bg-white/90 px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-sky-500 focus:outline-none" />
                    </div>
                    <button type="submit" class="w-full rounded-3xl bg-gradient-to-r from-sky-500 to-cyan-500 px-5 py-3 text-sm font-bold text-white transition hover:opacity-95">
                      Commander ce circuit
                    </button>
                  </form>

                  <details class="group rounded-3xl border border-slate-200/60 bg-white/80 p-4 transition hover:border-sky-300">
                    <summary class="flex cursor-pointer items-center justify-between text-sm font-semibold text-slate-800">
                      Laisser un avis au guide
                      <span class="text-sky-500">+</span>
                    </summary>
                    <form method="POST" action="/avis" class="mt-4 space-y-4">
                      <input type="hidden" name="id_plan" value="{{id}}" />
                      <input type="hidden" name="id_guide" value="{{../id}}" />
                      <div class="grid gap-3">
                        <div class="flex items-center gap-2 text-slate-700">
                          <span class="text-sm font-semibold">Note</span>
                          <span class="text-xs text-slate-400">(1 à 5 étoiles)</span>
                        </div>
                        <div class="flex items-center gap-1">
                          <label class="cursor-pointer text-2xl text-slate-300 transition hover:text-sky-500">
                            <input type="radio" name="note" value="1" class="sr-only" required />
                            ★
                          </label>
                          <label class="cursor-pointer text-2xl text-slate-300 transition hover:text-sky-500">
                            <input type="radio" name="note" value="2" class="sr-only" required />
                            ★
                          </label>
                          <label class="cursor-pointer text-2xl text-slate-300 transition hover:text-sky-500">
                            <input type="radio" name="note" value="3" class="sr-only" required />
                            ★
                          </label>
                          <label class="cursor-pointer text-2xl text-slate-300 transition hover:text-sky-500">
                            <input type="radio" name="note" value="4" class="sr-only" required />
                            ★
                          </label>
                          <label class="cursor-pointer text-2xl text-slate-300 transition hover:text-sky-500">
                            <input type="radio" name="note" value="5" class="sr-only" required />
                            ★
                          </label>
                        </div>
                      </div>
                      <div>
                        <label class="text-sm font-semibold text-slate-700">Commentaire</label>
                        <textarea name="commentaire" rows="3" placeholder="Votre retour..." class="mt-2 w-full rounded-3xl border border-slate-200 px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-sky-500 focus:outline-none"></textarea>
                      </div>
                      <button type="submit" class="w-full rounded-3xl bg-gradient-to-r from-emerald-500 to-teal-500 px-5 py-3 text-sm font-bold text-white transition hover:opacity-95">
                        Envoyer l'avis
                      </button>
                    </form>
                  </details>
                </div>
              </article>
            {{/each}}
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="rounded-[2rem] border border-slate-200/70 bg-white/90 p-16 text-center shadow-xl">
      <h2 class="text-3xl font-extrabold text-slate-900">Aucun guide actif pour le moment</h2>
      <p class="mt-4 text-slate-600">Nous mettons à jour les offres en continu. Revenez bientôt pour découvrir encore plus de circuits.</p>
      <a href="/plans" class="mt-6 inline-flex items-center gap-2 rounded-3xl bg-sky-600 hover:bg-sky-700 px-6 py-3 text-white font-semibold transition shadow-lg">
        <i class="fas fa-compass mr-1"></i>
        Découvrir les circuits
      </a>
    </div>
  {{/if}}
</section>

<script>
  async function cancelReservation(reservationId) {
    if (!confirm('Voulez-vous annuler cette réservation ?')) {
      return;
    }

    try {
      const response = await fetch(`/touriste/reservations/${reservationId}/cancel`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        }
      });

      if (response.ok) {
        alert('Réservation annulée avec succès.');
        window.location.reload();
      } else {
        alert('Impossible d\'annuler la réservation.');
      }
    } catch (error) {
      console.error('Erreur annulation réservation :', error);
      alert('Erreur de communication avec le serveur.');
    }
  }
</script>
