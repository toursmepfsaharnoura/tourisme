<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Réserver {{plan.titre}} - Tunisie Authentique</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    .glass {
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.25);
    }
    .card-hover {
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .card-hover:hover {
      transform: translateY(-10px) scale(1.02);
      box-shadow: 0 25px 50px rgba(0,0,0,0.3);
    }
  </style>
</head>
<body class="bg-gradient-to-br from-purple-900 via-blue-900 to-indigo-900 min-h-screen text-white">

  <!-- Navigation -->
  <nav class="fixed top-0 w-full z-50 glass backdrop-blur-md border-b border-white/20">
    <div class="max-w-7xl mx-auto px-6 py-4">
      <div class="flex items-center justify-between">
        <a href="/" class="text-2xl font-black text-yellow-400">
          <i class="fas fa-route mr-2"></i>
          Tunisie Authentique
        </a>
        <div class="flex items-center gap-4">
          <a href="/touriste/dashboard" class="glass px-4 py-2 rounded-xl font-semibold card-hover">
            <i class="fas fa-tachometer-alt mr-2"></i>
            Dashboard
          </a>
          <a href="/touriste/favorites" class="glass px-4 py-2 rounded-xl font-semibold card-hover">
            <i class="fas fa-heart mr-2"></i>
            Mes Favoris
          </a>
          <a href="/logout" class="bg-gradient-to-r from-red-500 to-pink-600 px-4 py-2 rounded-xl font-semibold card-hover">
            <i class="fas fa-sign-out-alt mr-2"></i>
            Déconnexion
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-6xl font-black mb-4">
          Réserver <span class="text-yellow-400">{{plan.titre}}</span>
        </h1>
        <p class="text-xl opacity-90">
          Complétez votre réservation pour ce circuit touristique
        </p>
      </div>
    </div>
  </section>

  <!-- Reservation Form -->
  <section class="px-6 pb-32">
    <div class="max-w-4xl mx-auto">
      <div class="glass rounded-3xl p-8 border-2 border-white/20">
        <h2 class="text-3xl font-black mb-8 text-center">Détails de la Réservation</h2>

        <form id="reservationForm" action="/reservations/touriste/reservations" method="POST" class="space-y-8">
          <input type="hidden" name="id_plan" value="{{plan.id}}">

          <!-- Plan Summary -->
          <div class="bg-white/10 rounded-2xl p-6">
            <h3 class="text-2xl font-bold mb-4 text-yellow-400">Circuit Sélectionné</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <p class="text-lg mb-2"><strong>Titre:</strong> {{plan.titre}}</p>
                <p class="text-lg mb-2"><strong>Description:</strong> {{plan.description}}</p>
                {{#if plan.prix}}
                <p class="text-lg mb-2"><strong>Prix:</strong> {{plan.prix}} TND</p>
                {{/if}}
                {{#if plan.capacite_max}}
                  <p class="text-lg mb-2"><strong>Capacité maximale:</strong> {{plan.capacite_max}} personne{{#unless (eq plan.capacite_max 1)}}s{{/unless}}</p>
                  <p class="text-lg mb-2"><strong>Places restantes:</strong> {{plan.places_restantes}} personne{{#unless (eq plan.places_restantes 1)}}s{{/unless}}</p>
                {{/if}}
              </div>
              <div>
                <p class="text-lg mb-2"><strong>Date de début:</strong> {{plan.date_debut}}</p>
                <p class="text-lg mb-2"><strong>Date de fin:</strong> {{plan.date_fin}}</p>
                <p class="text-lg mb-2"><strong>Guide:</strong> {{plan.guide_nom}}</p>
              </div>
            </div>
          </div>

          <!-- Reservation Details -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="date_reservation" class="block text-lg font-semibold mb-2">
                <i class="fas fa-calendar-alt mr-2 text-blue-400"></i>
                Date de Réservation
              </label>
              <input type="date" id="date_reservation" name="date_reservation"
                     class="w-full px-4 py-3 rounded-xl bg-white/20 border border-white/30 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-yellow-400"
                     required>
            </div>

            <div>
              <label for="nombre_personnes" class="block text-lg font-semibold mb-2">
                <i class="fas fa-users mr-2 text-green-400"></i>
                Nombre de Personnes
              </label>
              <input type="number" id="nombre_personnes" name="nombre_personnes" min="1" max="{{plan.places_restantes}}"
                     class="w-full px-4 py-3 rounded-xl bg-white/20 border border-white/30 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-yellow-400"
                     required>
              {{#if plan.places_restantes}}
                <p class="text-sm text-slate-300 mt-2">Jusqu'à {{plan.places_restantes}} personne{{#unless (eq plan.places_restantes 1)}}s{{/unless}} restantes.</p>
              {{/if}}
            </div>
          </div>

          <!-- Contact Information -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="email_contact" class="block text-lg font-semibold mb-2">
                <i class="fas fa-envelope mr-2 text-purple-400"></i>
                Email de Contact
              </label>
              <input type="email" id="email_contact" name="email_contact" value="{{tourist.email}}"
                     class="w-full px-4 py-3 rounded-xl bg-white/20 border border-white/30 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-yellow-400"
                     required>
            </div>

            <div>
              <label for="telephone_contact" class="block text-lg font-semibold mb-2">
                <i class="fas fa-phone mr-2 text-orange-400"></i>
                Téléphone de Contact
              </label>
              <input type="tel" id="telephone_contact" name="telephone_contact" value="{{tourist.telephone}}"
                     class="w-full px-4 py-3 rounded-xl bg-white/20 border border-white/30 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-yellow-400"
                     required>
            </div>
          </div>

          <!-- Message -->
          <div>
            <label for="message" class="block text-lg font-semibold mb-2">
              <i class="fas fa-comment mr-2 text-pink-400"></i>
              Message (optionnel)
            </label>
            <textarea id="message" name="message" rows="4"
                      class="w-full px-4 py-3 rounded-xl bg-white/20 border border-white/30 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-yellow-400"
                      placeholder="Ajoutez un message pour le guide..."></textarea>
          </div>

          <!-- Submit Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 pt-6 border-t border-white/30">
            {{#if plan.places_restantes}}
              <button type="submit" id="submitBtn" class="flex-1 bg-gradient-to-r from-yellow-400 to-orange-500 px-8 py-4 rounded-2xl font-bold text-gray-900 text-lg card-hover">
                <i class="fas fa-calendar-check mr-2"></i>
                Confirmer la Réservation
              </button>
            {{else}}
              <button type="button" disabled class="flex-1 bg-red-500/80 px-8 py-4 rounded-2xl font-bold text-white text-lg opacity-70 cursor-not-allowed">
                <i class="fas fa-ban mr-2"></i>
                Circuit complet
              </button>
            {{/if}}
            <a href="/plan/{{plan.id}}" class="flex-1 glass px-8 py-4 rounded-2xl font-bold text-center card-hover">
              <i class="fas fa-arrow-left mr-2"></i>
              Retour au Plan
            </a>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Success/Error Messages -->
  <div id="message" class="fixed top-4 right-4 p-4 rounded-xl shadow-lg transform translate-x-full transition-transform duration-300" style="display: none;">
    <div class="flex items-center">
      <i class="fas fa-check-circle text-green-400 mr-2"></i>
      <span id="messageText"></span>
    </div>
  </div>

  <!-- Footer -->
  <footer class="glass p-12 text-center border-t border-white/20">
    <p class="text-lg opacity-75">&copy; 2026 Tunisie Authentique. Tous droits réservés.</p>
  </footer>

  <script>
    document.getElementById('reservationForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const submitBtn = document.getElementById('submitBtn');
      const originalText = submitBtn.innerHTML;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Traitement...';
      submitBtn.disabled = true;

      try {
        const formData = new FormData(this);
        const response = await fetch(this.action, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'Accept': 'application/json'
          },
          body: new URLSearchParams(formData)
        });

        const result = await response.json();

        if (result.success) {
          showMessage('Réservation prête, redirection vers le paiement...', 'success');
          setTimeout(() => {
            window.location.href = result.payUrl || '/touriste/reservations/paiement';
          }, 1200);
        } else {
          showMessage(result.error || 'Erreur lors de la création', 'error');
          submitBtn.innerHTML = originalText;
          submitBtn.disabled = false;
        }
      } catch (error) {
        console.error('Error:', error);
        showMessage('Erreur lors de la création de la réservation', 'error');
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
      }
    });

    function showMessage(text, type) {
      const messageDiv = document.getElementById('message');
      const messageText = document.getElementById('messageText');
      const icon = messageDiv.querySelector('i');
      
      messageText.textContent = text;
      
      if (type === 'success') {
        messageDiv.className = 'fixed top-4 right-4 p-4 rounded-xl shadow-lg bg-green-500 text-white transform transition-transform duration-300';
        icon.className = 'fas fa-check-circle mr-2';
      } else {
        messageDiv.className = 'fixed top-4 right-4 p-4 rounded-xl shadow-lg bg-red-500 text-white transform transition-transform duration-300';
        icon.className = 'fas fa-exclamation-circle mr-2';
      }
      
      messageDiv.style.display = 'block';
      setTimeout(() => {
        messageDiv.classList.remove('translate-x-full');
      }, 100);
      
      setTimeout(() => {
        messageDiv.classList.add('translate-x-full');
        setTimeout(() => {
          messageDiv.style.display = 'none';
        }, 300);
      }, 3000);
    }
  </script>

</body>
</html>