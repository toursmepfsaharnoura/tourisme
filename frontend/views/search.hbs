<!-- Search Results Header -->
<section class="py-16 bg-gradient-to-b from-gray-50 to-white">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4 font-playfair">
        Search Results
      </h1>
      <p class="text-xl text-gray-600">
        {{#if query}}
          Found {{resultsCount}} destination{{#if (gt resultsCount 1)}}s{{/if}} for "<span class="text-ocean-blue font-semibold">{{query}}</span>"
        {{else}}
          Please enter a search term
        {{/if}}
      </p>
    </div>
    
    <!-- Search Bar -->
    <div class="max-w-2xl mx-auto mb-12">
      <form action="/search" method="GET" class="glass-morphism rounded-2xl p-2 flex flex-col md:flex-row gap-2">
        <div class="flex-1 flex items-center px-4">
          <i class="fas fa-search text-gray-400 mr-3"></i>
          <input 
            type="text" 
            name="q"
            value="{{query}}"
            placeholder="Search destinations..." 
            class="w-full bg-transparent text-gray-900 placeholder-gray-400 outline-none py-3"
          >
        </div>
        <button type="submit" class="desert-gradient px-8 py-3 rounded-xl font-semibold text-white button-glow hover:scale-105 transition-transform">
          Search
        </button>
      </form>
    </div>
    
    <!-- Results -->
    {{#if query}}
      {{#if (gt resultsCount 0)}}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
          {{#each gouvernorats}}
          <div class="group cursor-pointer" onclick="window.location.href='/gouvernorats/{{id}}/delegations'">
            <div class="relative overflow-hidden rounded-2xl card-hover">
              <!-- Destination Image -->
              <div class="h-64 bg-gradient-to-br from-ocean-blue to-desert-orange relative">
                <div class="absolute inset-0 flex items-center justify-center">
                  <i class="fas fa-map-marker-alt text-6xl text-white/30"></i>
                </div>
                <!-- Overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                
                <!-- Favorite Button -->
                <button class="absolute top-4 right-4 w-10 h-10 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center text-white hover:bg-white/30 transition-colors">
                  <i class="far fa-heart"></i>
                </button>
                
                <!-- Rating Badge -->
                <div class="absolute bottom-4 left-4 bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full">
                  <div class="flex items-center text-white text-sm">
                    <i class="fas fa-star text-yellow-400 mr-1"></i>
                    <span>4.8</span>
                  </div>
                </div>
              </div>
              
              <!-- Content -->
              <div class="p-6 bg-white rounded-b-2xl shadow-lg">
                <h3 class="text-xl font-bold text-gray-900 mb-2">{{nom}}</h3>
                <p class="text-gray-600 text-sm mb-4">Discover the wonders of {{nom}}</p>
                <div class="flex items-center justify-between">
                  <div class="flex items-center text-gray-500 text-sm">
                    <i class="fas fa-map-pin mr-2"></i>
                    <span>Tunisia</span>
                  </div>
                  <div class="text-ocean-blue font-semibold">
                    Explore →
                  </div>
                </div>
              </div>
            </div>
          </div>
          {{/each}}
        </div>
      {{else}}
        <!-- No Results -->
        <div class="text-center py-16">
          <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-search text-gray-400 text-3xl"></i>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">No destinations found</h3>
          <p class="text-gray-600 mb-8 max-w-md mx-auto">
            We couldn't find any destinations matching "{{query}}". Try searching with different keywords.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/" class="bg-ocean-blue hover:bg-ocean-dark text-white font-semibold py-3 px-6 rounded-xl transition-colors">
              <i class="fas fa-home mr-2"></i>
              Back to Home
            </a>
            <a href="/gouvernorats/1/delegations" class="desert-gradient text-white font-semibold py-3 px-6 rounded-xl transition-colors">
              <i class="fas fa-map-marked-alt mr-2"></i>
              Browse All Destinations
            </a>
          </div>
        </div>
      {{/if}}
    {{else}}
      <!-- Empty Search -->
      <div class="text-center py-16">
        <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <i class="fas fa-search text-gray-400 text-3xl"></i>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Search for destinations</h3>
        <p class="text-gray-600 mb-8 max-w-md mx-auto">
          Enter a destination name in the search bar above to find amazing places to visit in Tunisia.
        </p>
        <a href="/" class="bg-ocean-blue hover:bg-ocean-dark text-white font-semibold py-3 px-6 rounded-xl transition-colors">
          <i class="fas fa-home mr-2"></i>
          Back to Home
        </a>
      </div>
    {{/if}}
  </div>
</section>

<!-- Popular Destinations Section -->
{{#if query}}
  {{#if (lt resultsCount 3)}}
    <section class="py-20 bg-gradient-to-b from-white to-gray-50">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Popular Destinations</h2>
          <p class="text-xl text-gray-600">
            Explore these amazing places in Tunisia
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="group cursor-pointer" onclick="window.location.href='/gouvernorats/1/delegations'">
            <div class="relative overflow-hidden rounded-2xl card-hover">
              <div class="h-48 bg-gradient-to-br from-blue-500 to-cyan-400 relative flex items-center justify-center">
                <i class="fas fa-umbrella-beach text-white text-4xl"></i>
              </div>
              <div class="p-4 bg-white">
                <h3 class="font-bold text-gray-900">Tunis</h3>
                <p class="text-gray-600 text-sm">Capital city with rich history</p>
              </div>
            </div>
          </div>
          
          <div class="group cursor-pointer" onclick="window.location.href='/gouvernorats/2/delegations'">
            <div class="relative overflow-hidden rounded-2xl card-hover">
              <div class="h-48 bg-gradient-to-br from-orange-500 to-red-400 relative flex items-center justify-center">
                <i class="fas fa-sun text-white text-4xl"></i>
              </div>
              <div class="p-4 bg-white">
                <h3 class="font-bold text-gray-900">Sfax</h3>
                <p class="text-gray-600 text-sm">Beautiful coastal city</p>
              </div>
            </div>
          </div>
          
          <div class="group cursor-pointer" onclick="window.location.href='/gouvernorats/3/delegations'">
            <div class="relative overflow-hidden rounded-2xl card-hover">
              <div class="h-48 bg-gradient-to-br from-green-500 to-teal-400 relative flex items-center justify-center">
                <i class="fas fa-mountain text-white text-4xl"></i>
              </div>
              <div class="p-4 bg-white">
                <h3 class="font-bold text-gray-900">Sousse</h3>
                <p class="text-gray-600 text-sm">Resort paradise</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  {{/if}}
{{/if}}
